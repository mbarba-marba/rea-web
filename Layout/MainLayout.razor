@inherits LayoutComponentBase

<div class="@LayoutClass">
    <Sidebar CollapsedChanged="OnSidebarCollapsedChanged" ThemeChanged="OnThemeChanged" />
    <TopBar SidebarCollapsed="_sidebarCollapsed" />
    <main class="main-content page-enter">
        @Body
    </main>
</div>

@code {
    private bool _sidebarCollapsed;
    private bool _darkTheme;

    private string LayoutClass
    {
        get
        {
            var classes = "app-layout";
            if (_sidebarCollapsed)
            {
                classes += " sidebar-collapsed";
            }

            if (_darkTheme)
            {
                classes += " theme-dark";
            }

            return classes;
        }
    }

    private void OnSidebarCollapsedChanged(bool collapsed)
    {
        _sidebarCollapsed = collapsed;
    }

    private void OnThemeChanged(bool darkTheme)
    {
        _darkTheme = darkTheme;
    }
}
