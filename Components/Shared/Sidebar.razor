@using Microsoft.AspNetCore.Components.Authorization
@using REA.Web.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthService AuthService
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS

@code {
    [Parameter] public EventCallback<bool> CollapsedChanged { get; set; }
    [Parameter] public EventCallback<bool> ThemeChanged { get; set; }
}

<aside class="rea-sidebar fixed left-0 top-0 bottom-0 z-[100] flex flex-col
              bg-white/60 backdrop-blur-xl border-r border-white/40
              shadow-[4px_0_24px_rgba(0,0,0,0.04)]
              transition-[width] duration-[280ms] ease-[cubic-bezier(0.4,0,0.2,1)] overflow-hidden
              @(_collapsed ? "w-16" : "w-64")">

    @* Brand *@
    <div class="flex items-center gap-2.5 px-3 border-b border-black/[0.06] flex-shrink-0 h-14">
        <div class="w-7 h-7 rounded-lg bg-[#076280] flex items-center justify-center flex-shrink-0 shadow-sm">
            <span class="text-white text-[12px] font-bold tracking-wide">R</span>
        </div>
        <span class="@BrandTextCls">REA</span>
    </div>

    @* Nav *@
    <nav class="flex-1 flex flex-col gap-0.5 p-2 overflow-y-auto overflow-x-hidden">

        <NavLink href="/" Match="NavLinkMatch.All" title="Dashboard"
                 class="@NavCls">
            <span class="@IconCls"><LucideIcon Name="layout-dashboard" Size="18" /></span>
            <span class="@LabelCls">Dashboard</span>
        </NavLink>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/clientes" Match="NavLinkMatch.Prefix" title="Clientes"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="users" Size="18" /></span>
                <span class="@LabelCls">Clientes</span>
            </NavLink>
        </AuthorizeView>

        <NavLink href="/checklists" Match="NavLinkMatch.Prefix" title="Libro de Trabajo"
                 class="@NavCls">
            <span class="@IconCls"><LucideIcon Name="list-checks" Size="18" /></span>
            <span class="@LabelCls">Libro de Trabajo</span>
        </NavLink>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/xml" Match="NavLinkMatch.Prefix" title="XML &amp; Facturas"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="file-archive" Size="18" /></span>
                <span class="@LabelCls">XML &amp; Facturas</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/calculos" Match="NavLinkMatch.Prefix" title="Cálculos ISR/IVA"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="calculator" Size="18" /></span>
                <span class="@LabelCls">Cálculos ISR/IVA</span>
            </NavLink>
        </AuthorizeView>

        <NavLink href="/reportes" Match="NavLinkMatch.Prefix" title="Reportes"
                 class="@NavCls">
            <span class="@IconCls"><LucideIcon Name="scroll-text" Size="18" /></span>
            <span class="@LabelCls">Reportes</span>
        </NavLink>

        <AuthorizeView Roles="admin">
            <div class="mt-2 mb-1 px-2">
                <span class="@(_collapsed ? "hidden" : "block text-[10px] font-semibold uppercase tracking-widest text-gray-400")">
                    Admin
                </span>
                <div class="@(_collapsed ? "block h-px bg-black/[0.06] mx-1" : "hidden")"></div>
            </div>

            <NavLink href="/periodos" Match="NavLinkMatch.Prefix" title="Periodos Fiscales"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="calendar-range" Size="18" /></span>
                <span class="@LabelCls">Periodos Fiscales</span>
            </NavLink>

            <NavLink href="/usuarios" Match="NavLinkMatch.Prefix" title="Usuarios"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="shield-check" Size="18" /></span>
                <span class="@LabelCls">Usuarios</span>
            </NavLink>

            <NavLink href="/asignaciones" Match="NavLinkMatch.Prefix" title="Asignaciones"
                     class="@NavCls">
                <span class="@IconCls"><LucideIcon Name="link" Size="18" /></span>
                <span class="@LabelCls">Asignaciones</span>
            </NavLink>
        </AuthorizeView>

    </nav>

    @* Footer *@
    <div class="p-2 border-t border-black/[0.06] flex flex-col gap-0.5">
        <button @onclick="ToggleTheme" title="@(_isDarkMode ? "Modo claro" : "Modo oscuro")"
                class="@BtnNavCls">
            <span class="@IconCls"><LucideIcon Name="@(_isDarkMode ? "sun" : "moon")" Size="18" /></span>
            <span class="@LabelCls">@(_isDarkMode ? "Modo claro" : "Modo oscuro")</span>
        </button>
        <button @onclick="ToggleCollapse" title="@(_collapsed ? "Expandir" : "Colapsar")"
                class="@BtnNavCls">
            <span class="@IconCls"><LucideIcon Name="@(_collapsed ? "panel-left-open" : "panel-left-close")" Size="18" /></span>
            <span class="@LabelCls">@(_collapsed ? "Expandir" : "Colapsar")</span>
        </button>
        <button @onclick="AbrirConfig" title="Configuración"
                class="@BtnNavCls">
            <span class="@IconCls"><LucideIcon Name="settings" Size="18" /></span>
            <span class="@LabelCls">Configuración</span>
        </button>
    </div>

</aside>

@* Modal Configuración *@
@if (_modalConfig)
{
    <div class="fixed inset-0 bg-black/30 backdrop-blur-sm z-[1000] flex items-center justify-center"
         @onclick="CerrarConfig">
        <div class="bg-white/90 backdrop-blur-xl border border-white/40 rounded-2xl shadow-2xl
                    w-[360px] overflow-hidden"
             @onclick:stopPropagation="true">

            @* Header *@
            <div class="flex items-center justify-between px-5 py-4 border-b border-black/[0.06]">
                <div class="flex items-center gap-2 text-gray-800 font-semibold">
                    <LucideIcon Name="settings" Size="18" />
                    <span>Configuración</span>
                </div>
                <button @onclick="CerrarConfig"
                        class="w-7 h-7 flex items-center justify-center rounded-lg
                               text-gray-400 hover:text-gray-700 hover:bg-black/[0.06]
                               border-0 bg-transparent outline-none cursor-pointer transition-colors">
                    <LucideIcon Name="x" Size="15" />
                </button>
            </div>

            @* User info *@
            <div class="flex items-center gap-3 px-5 py-4 border-b border-black/[0.06]">
                <div class="w-10 h-10 rounded-full bg-[#bbe7ef] text-[#076280]
                            flex items-center justify-center font-bold text-base flex-shrink-0">
                    @_userInitial
                </div>
                <div class="min-w-0">
                    <div class="font-medium text-sm text-gray-900 truncate">@_userName</div>
                    <div class="text-xs text-gray-500 truncate">@_userEmail</div>
                </div>
            </div>

            @* Options *@
            <div class="p-3 flex flex-col gap-0.5">
                <button @onclick="IrAPerfil"
                        class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm text-gray-600
                               hover:bg-[#076280]/[0.06] hover:text-[#076280] transition-colors
                               border-0 bg-transparent outline-none cursor-pointer text-left">
                    <LucideIcon Name="pencil" Size="16" />
                    <span>Editar perfil</span>
                </button>
                <button @onclick="IrAPerfilPassword"
                        class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm text-gray-600
                               hover:bg-[#076280]/[0.06] hover:text-[#076280] transition-colors
                               border-0 bg-transparent outline-none cursor-pointer text-left">
                    <LucideIcon Name="eye" Size="16" />
                    <span>Cambiar contraseña</span>
                </button>
            </div>

            @* Logout *@
            <div class="px-3 pb-3">
                <button @onclick="Logout"
                        class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm text-red-500
                               hover:bg-red-50 transition-colors
                               border-0 bg-transparent outline-none cursor-pointer text-left font-medium">
                    <LucideIcon Name="log-out" Size="16" />
                    <span>Cerrar sesión</span>
                </button>
            </div>

        </div>
    </div>
}

@code {
    private bool _collapsed;
    private bool _modalConfig;
    private bool _isDarkMode;
    private string _userName = "";
    private string _userEmail = "";
    private string _userInitial = "U";

    // Computed class strings — defined once, reused across every nav item
    private string NavCls => _collapsed
        ? "relative flex items-center justify-center h-10 w-10 rounded-lg text-gray-500 no-underline transition-colors duration-150 hover:bg-[#076280]/[0.06] hover:text-[#076280] cursor-pointer overflow-hidden [&.active]:bg-[#076280]/10 [&.active]:text-[#076280] [&.active]:font-medium"
        : "relative flex items-center gap-2.5 h-10 px-2 rounded-lg text-sm text-gray-500 no-underline transition-colors duration-150 hover:bg-[#076280]/[0.06] hover:text-[#076280] cursor-pointer w-full overflow-hidden [&.active]:bg-[#076280]/10 [&.active]:text-[#076280] [&.active]:font-medium [&.active]:border-l-2 [&.active]:border-[#076280] [&.active]:pl-[calc(0.5rem-2px)]";

    private string BrandTextCls => "font-semibold text-[15px] text-gray-900 whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-[280ms] ease-[cubic-bezier(0.4,0,0.2,1)] "
        + (_collapsed ? "max-w-0 opacity-0" : "flex-1 max-w-[200px] opacity-100");

    private string IconCls => _collapsed
        ? "w-5 h-5 flex items-center justify-center flex-shrink-0"
        : "w-5 h-5 flex items-center justify-center flex-shrink-0 text-gray-400";

    private string LabelCls => _collapsed
        ? "hidden"
        : "truncate text-[13.5px]";

    private string BtnNavCls => (_collapsed
        ? "flex items-center justify-center h-10 w-10 rounded-lg text-gray-500 transition-colors duration-150 hover:bg-[#076280]/[0.06] hover:text-[#076280] cursor-pointer overflow-hidden"
        : "flex items-center gap-2.5 h-10 px-2 rounded-lg text-sm text-gray-500 transition-colors duration-150 hover:bg-[#076280]/[0.06] hover:text-[#076280] cursor-pointer w-full overflow-hidden")
        + " border-0 bg-transparent outline-none text-left";

    protected override async Task OnInitializedAsync()
    {
        var saved = await LocalStorage.GetAsync("rea_sidebar_collapsed");
        _collapsed = saved == "true";
        await CollapsedChanged.InvokeAsync(_collapsed);
        await ApplySidebarLayoutAsync(_collapsed);

        var savedTheme = await LocalStorage.GetAsync("rea_theme");
        _isDarkMode = savedTheme == "dark";
        await ThemeChanged.InvokeAsync(_isDarkMode);
        await ApplyThemeAsync(_isDarkMode);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userEmail = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value
                      ?? user.FindFirst(c => c.Type == "email")?.Value ?? "";
            _userName  = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value
                      ?? user.FindFirst(c => c.Type == "name")?.Value ?? _userEmail;
            _userInitial = _userName.Length > 0 ? _userName[0].ToString().ToUpper() : "U";
        }
    }

    private async Task ToggleCollapse()
    {
        _collapsed = !_collapsed;
        await LocalStorage.SetAsync("rea_sidebar_collapsed", _collapsed ? "true" : "false");
        await CollapsedChanged.InvokeAsync(_collapsed);
        await ApplySidebarLayoutAsync(_collapsed);
    }

    private void AbrirConfig() => _modalConfig = true;
    private void CerrarConfig() => _modalConfig = false;

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetAsync("rea_theme", _isDarkMode ? "dark" : "light");
        await ThemeChanged.InvokeAsync(_isDarkMode);
        await ApplyThemeAsync(_isDarkMode);
    }

    private async Task ApplyThemeAsync(bool darkMode)
    {
        await JS.InvokeVoidAsync("reaTheme.apply", darkMode ? "dark" : "light");
    }

    private async Task ApplySidebarLayoutAsync(bool collapsed)
    {
        await JS.InvokeVoidAsync("reaLayout.setSidebarCollapsed", collapsed);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ApplySidebarLayoutAsync(_collapsed);
        await ApplyThemeAsync(_isDarkMode);
    }

    private void IrAPerfil()        { _modalConfig = false; Navigation.NavigateTo("/perfil"); }
    private void IrAPerfilPassword() { _modalConfig = false; Navigation.NavigateTo("/perfil"); }

    private async Task Logout()
    {
        _modalConfig = false;
        await AuthService.LogoutAsync();
        var auth = (Providers.ReaAuthStateProvider)AuthStateProvider;
        await auth.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/login");
    }
}
