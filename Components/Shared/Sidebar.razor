@using Microsoft.AspNetCore.Components.Authorization
@using REA.Web.Services
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject AuthService AuthService
@inject ILocalStorageService LocalStorage

<aside class="sidebar @(_collapsed ? "sidebar--collapsed" : "")">

    <div class="sidebar-brand">
        <div class="sidebar-brand-logo">
            <span class="sidebar-brand-initials">R</span>
        </div>
        <span class="sidebar-brand-text">REA</span>
        <button class="sidebar-toggle" @onclick="ToggleCollapse"
                title="@(_collapsed ? "Expandir menú" : "Colapsar menú")">
            <LucideIcon Name="@(_collapsed ? "chevron-right" : "chevron-left")" Size="16" />
        </button>
    </div>

    <nav class="sidebar-nav">
        <NavLink href="/" Match="NavLinkMatch.All" class="nav-item" title="Dashboard">
            <span class="nav-item-icon"><LucideIcon Name="layout-dashboard" Size="18" /></span>
            <span class="nav-item-label">Dashboard</span>
        </NavLink>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/clientes" Match="NavLinkMatch.Prefix" class="nav-item" title="Clientes">
                <span class="nav-item-icon"><LucideIcon Name="users" Size="18" /></span>
                <span class="nav-item-label">Clientes</span>
            </NavLink>
        </AuthorizeView>

        <NavLink href="/checklists" Match="NavLinkMatch.Prefix" class="nav-item" title="Libro de Trabajo">
            <span class="nav-item-icon"><LucideIcon Name="list-checks" Size="18" /></span>
            <span class="nav-item-label">Libro de Trabajo</span>
        </NavLink>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/xml" Match="NavLinkMatch.Prefix" class="nav-item" title="XML &amp; Facturas">
                <span class="nav-item-icon"><LucideIcon Name="file-archive" Size="18" /></span>
                <span class="nav-item-label">XML &amp; Facturas</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="admin,auxiliar">
            <NavLink href="/calculos" Match="NavLinkMatch.Prefix" class="nav-item" title="Cálculos ISR/IVA">
                <span class="nav-item-icon"><LucideIcon Name="calculator" Size="18" /></span>
                <span class="nav-item-label">Cálculos ISR/IVA</span>
            </NavLink>
        </AuthorizeView>

        <NavLink href="/reportes" Match="NavLinkMatch.Prefix" class="nav-item" title="Reportes">
            <span class="nav-item-icon"><LucideIcon Name="scroll-text" Size="18" /></span>
            <span class="nav-item-label">Reportes</span>
        </NavLink>

        <AuthorizeView Roles="admin">
            <NavLink href="/periodos" Match="NavLinkMatch.Prefix" class="nav-item" title="Periodos Fiscales">
                <span class="nav-item-icon"><LucideIcon Name="calendar-range" Size="18" /></span>
                <span class="nav-item-label">Periodos Fiscales</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="admin">
            <NavLink href="/usuarios" Match="NavLinkMatch.Prefix" class="nav-item" title="Usuarios">
                <span class="nav-item-icon"><LucideIcon Name="shield-check" Size="18" /></span>
                <span class="nav-item-label">Usuarios</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="admin">
            <NavLink href="/asignaciones" Match="NavLinkMatch.Prefix" class="nav-item" title="Asignaciones">
                <span class="nav-item-icon"><LucideIcon Name="link" Size="18" /></span>
                <span class="nav-item-label">Asignaciones</span>
            </NavLink>
        </AuthorizeView>
    </nav>

    <div class="sidebar-footer">
        <button class="nav-item sidebar-settings-btn" @onclick="AbrirConfig" title="Configuración">
            <span class="nav-item-icon"><LucideIcon Name="settings" Size="18" /></span>
            <span class="nav-item-label">Configuración</span>
        </button>
    </div>

</aside>

@* Modal Configuración *@
@if (_modalConfig)
{
    <div class="modal-backdrop" @onclick="CerrarConfig">
        <div class="modal-container" style="max-width:400px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:10px;">
                    <LucideIcon Name="settings" Size="20" />
                    <h3 style="margin:0;">Configuración</h3>
                </div>
                <button class="sidebar-settings-btn" style="width:28px;height:28px;" @onclick="CerrarConfig">
                    <LucideIcon Name="x" Size="16" />
                </button>
            </div>

            <div class="modal-body">
                @* Usuario actual *@
                <div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border-subtle);margin-bottom:16px;">
                    <div style="width:40px;height:40px;border-radius:50%;background:var(--accent-light);color:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:600;font-size:16px;flex-shrink:0;">
                        @(_userInitial)
                    </div>
                    <div>
                        <div style="font-weight:500;font-size:14px;">@_userName</div>
                        <div style="font-size:12px;color:var(--text-secondary);">@_userEmail</div>
                    </div>
                </div>

                @* Opciones *@
                <div style="display:flex;flex-direction:column;gap:4px;">
                    <button class="config-option" @onclick="IrAPerfil">
                        <LucideIcon Name="pencil" Size="16" />
                        <span>Editar perfil</span>
                    </button>
                    <button class="config-option" @onclick="IrAPerfilPassword">
                        <LucideIcon Name="eye" Size="16" />
                        <span>Cambiar contraseña</span>
                    </button>
                </div>
            </div>

            <div class="modal-footer" style="justify-content:flex-start;">
                <GlassButton Variant="ghost" OnClick="Logout">
                    <LucideIcon Name="log-out" Size="15" /> Cerrar sesión
                </GlassButton>
            </div>
        </div>
    </div>
}

@code {
    private bool _collapsed;
    private bool _modalConfig;
    private string _userName = "";
    private string _userEmail = "";
    private string _userInitial = "U";

    protected override async Task OnInitializedAsync()
    {
        var saved = await LocalStorage.GetAsync("rea_sidebar_collapsed");
        _collapsed = saved == "true";

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userEmail = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value
                      ?? user.FindFirst(c => c.Type == "email")?.Value ?? "";
            _userName  = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value
                      ?? user.FindFirst(c => c.Type == "name")?.Value ?? _userEmail;
            _userInitial = _userName.Length > 0 ? _userName[0].ToString().ToUpper() : "U";
        }
    }

    private async Task ToggleCollapse()
    {
        _collapsed = !_collapsed;
        await LocalStorage.SetAsync("rea_sidebar_collapsed", _collapsed ? "true" : "false");
    }

    private void AbrirConfig() => _modalConfig = true;
    private void CerrarConfig() => _modalConfig = false;

    private void IrAPerfil()
    {
        _modalConfig = false;
        Navigation.NavigateTo("/perfil");
    }

    private void IrAPerfilPassword()
    {
        _modalConfig = false;
        Navigation.NavigateTo("/perfil");
    }

    private async Task Logout()
    {
        _modalConfig = false;
        await AuthService.LogoutAsync();
        var auth = (Providers.ReaAuthStateProvider)AuthStateProvider;
        await auth.MarkUserAsLoggedOut();
        Navigation.NavigateTo("/login");
    }
}
