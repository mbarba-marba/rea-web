<div class="modal-backdrop" @onclick="OnBackdropClick">
    <div class="modal-dialog glass-elevation-2" @onclick:stopPropagation style="@($"max-width:{MaxWidth}px;")">
        <div class="modal-header">
            <h3>@Title</h3>
            <button class="btn-ghost" @onclick="Hide"><LucideIcon Name="x" Size="18" /></button>
        </div>
        <div class="modal-body">
            @ChildContent
        </div>
        @if (Footer != null)
        {
            <div class="modal-footer">@Footer</div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Modal";
    [Parameter] public int MaxWidth { get; set; } = 520;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _visible;

    public void Show() { _visible = true; StateHasChanged(); }
    public void Hide() { _visible = false; StateHasChanged(); }

    private async Task OnBackdropClick()
    {
        _visible = false;
        await OnClose.InvokeAsync();
    }
}
