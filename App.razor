@using Microsoft.AspNetCore.Components.Authorization
@using REA.Web.Layout

@inject NavigationManager Navigation

<ErrorBoundary>
    <ChildContent>
        <CascadingAuthenticationState>
            <Router AppAssembly="@typeof(App).Assembly">
                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                        <NotAuthorized>
                            <AuthorizeView>
                                <Authorized Context="auth">
                                    <LayoutView Layout="@typeof(AuthLayout)">
                                        <div class="login-card glass-elevation-2" style="text-align:center;max-width:440px;margin:60px auto;">
                                            <LucideIcon Name="shield-off" Size="48" />
                                            <h2 style="margin:12px 0 4px;">Acceso denegado</h2>
                                            <p style="color:var(--text-secondary);margin-bottom:20px;">No tienes permisos para acceder a esta sección.</p>
                                            <button class="btn btn-primary" @onclick="IrDashboard">Ir al Dashboard</button>
                                        </div>
                                    </LayoutView>
                                </Authorized>
                                <NotAuthorized Context="anon">
                                    <RedirectToLogin />
                                </NotAuthorized>
                            </AuthorizeView>
                        </NotAuthorized>
                        <Authorizing>
                            <AuthLayout />
                        </Authorizing>
                    </AuthorizeRouteView>
                </Found>
                <NotFound>
                    <LayoutView Layout="@typeof(AuthLayout)">
                        <REA.Web.Pages.Error.NotFoundPage />
                    </LayoutView>
                </NotFound>
            </Router>
        </CascadingAuthenticationState>
    </ChildContent>
    <ErrorContent>
        <AuthLayout>
            <div class="error-banner" style="max-width:400px;margin:40px auto;text-align:center;">
                <LucideIcon Name="circle-alert" Size="48" />
                <h2 style="margin:12px 0 4px;">Algo salio mal</h2>
                <p style="color:var(--text-secondary);margin-bottom:16px;">Error al cargar la aplicacion</p>
                <button class="btn btn-primary" @onclick="Recargar">Recargar</button>
            </div>
        </AuthLayout>
    </ErrorContent>
</ErrorBoundary>

@code {
    private void Recargar() => Navigation.NavigateTo("/", forceLoad: true);
    private void IrDashboard() => Navigation.NavigateTo("/");
}
