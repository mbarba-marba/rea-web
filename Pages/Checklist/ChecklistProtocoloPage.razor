@page "/checklists/protocolo"
@using Microsoft.AspNetCore.Authorization
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin")]
@inject ChecklistService ChecklistService
@inject NavigationManager Navigation

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:20px;align-items:flex-start;gap:16px;">
        <div class="page-header-left">
            <h1>Protocolo Checklist</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Configura los candados operativos que solo se aplican al trabajo de auxiliares en cada uno de los 14 pasos.</p>
        </div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <GlassButton Variant="secondary" OnClick='() => Navigation.NavigateTo("/checklists")'>
                <LucideIcon Name="arrow-left" Size="16" /> Volver a checklists
            </GlassButton>
            <GlassButton Variant="primary" OnClick="Guardar" Disabled="@(_guardando || _cargando)">
                <LucideIcon Name="save" Size="16" /> @(_guardando ? "Guardando..." : "Guardar protocolo")
            </GlassButton>
        </div>
    </div>

    @if (_mensaje != null)
    {
        <div class="card" style="margin-bottom:16px;padding:14px 16px;border-color:@(_mensajeError ? "rgba(239,68,68,0.24)" : "rgba(16,185,129,0.24)");background:@(_mensajeError ? "rgba(239,68,68,0.08)" : "rgba(16,185,129,0.10)");">
            <div style="display:flex;align-items:center;gap:10px;color:@(_mensajeError ? "var(--danger)" : "var(--success)");font-weight:600;">
                <LucideIcon Name="@(_mensajeError ? "alert-circle" : "badge-check")" Size="18" />
                <span>@_mensaje</span>
            </div>
        </div>
    }

    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:16px;">
            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Pasos con nota</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_pasos.Count(x => x.NotaObligatoriaAuxiliar)</div>
                <div class="body-small text-muted" style="margin-top:4px;">Exigen bitácora antes de cerrar.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Pasos con evidencia</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_pasos.Count(x => x.EvidenciaObligatoriaAuxiliar)</div>
                <div class="body-small text-muted" style="margin-top:4px;">Exigen documento de respaldo.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Cierre solo admin</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_pasos.Count(x => x.RequiereCierreAdminAuxiliar)</div>
                <div class="body-small text-muted" style="margin-top:4px;">Necesitan validación final administrativa.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Pasos protegidos</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_pasos.Count(x => TieneReglasActivas(x))</div>
                <div class="body-small text-muted" style="margin-top:4px;">Impactan checklists abiertos y existentes.</div>
            </div>
        </div>

        <div class="card" style="padding:0;overflow:hidden;">
            <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                <div>
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Seguridad operativa</div>
                    <h3 style="margin-top:4px;">Reglas por número de paso</h3>
                </div>
                <div class="body-small text-muted">Los auxiliares pueden trabajar el paso, pero el cierre y los requisitos obedecen esta matriz.</div>
            </div>

            <div style="padding:18px 20px;display:grid;gap:12px;">
                @foreach (var paso in _pasos.OrderBy(x => x.NumeroPaso))
                {
                    <div class="card" style="padding:16px 18px;background:color-mix(in srgb, var(--glass-bg-primary) 86%, var(--bg-base) 14%);">
                        <div style="display:grid;grid-template-columns:auto minmax(0,1.2fr) repeat(3,minmax(180px,0.8fr));gap:14px;align-items:center;">
                            <div style="width:44px;height:44px;border-radius:12px;border:1px solid var(--border-subtle);display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--text-primary);background:var(--surface-raised);">
                                @paso.NumeroPaso
                            </div>

                            <div style="min-width:0;">
                                <div style="font-weight:700;color:var(--text-primary);">@paso.NombrePaso</div>
                                <div class="body-small text-muted" style="margin-top:4px;">
                                    @if (TieneReglasActivas(paso))
                                    {
                                        <span>Protocolo activo para auxiliares.</span>
                                    }
                                    else
                                    {
                                        <span>Sin candados adicionales en este paso.</span>
                                    }
                                </div>
                            </div>

                            <label style="display:flex;align-items:center;gap:10px;color:var(--text-primary);font-size:13px;font-weight:600;">
                                <input type="checkbox" @bind="paso.NotaObligatoriaAuxiliar" style="width:18px;height:18px;" />
                                <span>Nota obligatoria</span>
                            </label>

                            <label style="display:flex;align-items:center;gap:10px;color:var(--text-primary);font-size:13px;font-weight:600;">
                                <input type="checkbox" @bind="paso.EvidenciaObligatoriaAuxiliar" style="width:18px;height:18px;" />
                                <span>Evidencia obligatoria</span>
                            </label>

                            <label style="display:flex;align-items:center;gap:10px;color:var(--text-primary);font-size:13px;font-weight:600;">
                                <input type="checkbox" @bind="paso.RequiereCierreAdminAuxiliar" style="width:18px;height:18px;" />
                                <span>Cierre solo admin</span>
                            </label>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private readonly List<BreadcrumbItem> _breadcrumb = new()
    {
        new() { Text = "Inicio", Url = "/" },
        new() { Text = "Checklists", Url = "/checklists" },
        new() { Text = "Protocolo", Url = "/checklists/protocolo" }
    };

    private List<UpdateProtocoloPasoChecklistItemRequest> _pasos = new();
    private bool _cargando = true;
    private bool _guardando;
    private string? _mensaje;
    private bool _mensajeError;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _mensaje = null;

        try
        {
            var result = await ChecklistService.ObtenerProtocoloAsync();
            if (result?.Ok == true && result.Data != null)
            {
                _pasos = result.Data.Pasos
                    .OrderBy(x => x.NumeroPaso)
                    .Select(x => new UpdateProtocoloPasoChecklistItemRequest
                    {
                        NumeroPaso = x.NumeroPaso,
                        NombrePaso = x.NombrePaso,
                        NotaObligatoriaAuxiliar = x.NotaObligatoriaAuxiliar,
                        EvidenciaObligatoriaAuxiliar = x.EvidenciaObligatoriaAuxiliar,
                        RequiereCierreAdminAuxiliar = x.RequiereCierreAdminAuxiliar
                    })
                    .ToList();
            }
            else
            {
                _mensaje = result?.Error?.Message ?? "No se pudo cargar el protocolo.";
                _mensajeError = true;
            }
        }
        catch (Exception ex)
        {
            _mensaje = ex.Message;
            _mensajeError = true;
        }

        _cargando = false;
    }

    private async Task Guardar()
    {
        _guardando = true;
        _mensaje = null;

        try
        {
            var result = await ChecklistService.ActualizarProtocoloAsync(new UpdateProtocoloChecklistRequest
            {
                Pasos = _pasos
            });

            if (result?.Ok == true && result.Data != null)
            {
                _pasos = result.Data.Pasos
                    .OrderBy(x => x.NumeroPaso)
                    .Select(x => new UpdateProtocoloPasoChecklistItemRequest
                    {
                        NumeroPaso = x.NumeroPaso,
                        NombrePaso = x.NombrePaso,
                        NotaObligatoriaAuxiliar = x.NotaObligatoriaAuxiliar,
                        EvidenciaObligatoriaAuxiliar = x.EvidenciaObligatoriaAuxiliar,
                        RequiereCierreAdminAuxiliar = x.RequiereCierreAdminAuxiliar
                    })
                    .ToList();

                _mensaje = "Protocolo guardado correctamente.";
                _mensajeError = false;
            }
            else
            {
                _mensaje = result?.Error?.Message ?? "No se pudo guardar el protocolo.";
                _mensajeError = true;
            }
        }
        catch (Exception ex)
        {
            _mensaje = ex.Message;
            _mensajeError = true;
        }

        _guardando = false;
    }

    private static bool TieneReglasActivas(UpdateProtocoloPasoChecklistItemRequest paso)
        => paso.NotaObligatoriaAuxiliar || paso.EvidenciaObligatoriaAuxiliar || paso.RequiereCierreAdminAuxiliar;
}
