    private void AbrirSiguientePaso()
    {
        if (_siguientePaso == null)
        {
            return;
        }

        Navigation.NavigateTo($"/checklists/{ChecklistId}/paso/{_siguientePaso.PasoId}");
    }

    private static PasoDto? ObtenerSiguientePaso(IEnumerable<PasoDto> pasos, PasoDto actual)
    {
        var lista = pasos.OrderBy(p => p.NumeroPaso).ToList();

        var siguienteDespues = lista.FirstOrDefault(p =>
            p.NumeroPaso > actual.NumeroPaso &&
            NormalizarEstado(p.Estado) != "completado");

        if (siguienteDespues != null)
        {
            return siguienteDespues;
        }

        return lista.FirstOrDefault(p =>
            p.PasoId != actual.PasoId &&
            NormalizarEstado(p.Estado) != "completado");
    }

    private string? ObtenerMensajeBloqueoCompletar()
    {
        if (_paso?.Protocolo == null || !_paso.Protocolo.TieneReglasActivas)
        {
            return null;
        }

        if (_esAuxiliar && _paso.Protocolo.RequiereCierreAdminAuxiliar)
        {
            return "Este paso debe cerrarlo un administrador, aunque el checklist este asignado a tu cartera.";
        }

        var faltantes = new List<string>();
        if (_paso.Protocolo.NotaObligatoriaAuxiliar && !TieneNotaOperativa)
        {
            faltantes.Add("falta la nota obligatoria");
        }

        if (_paso.Protocolo.EvidenciaObligatoriaAuxiliar && !TieneEvidencias)
        {
            faltantes.Add("falta la evidencia obligatoria");
        }

        if (faltantes.Count == 0)
        {
            return null;
        }

        if (_esAuxiliar)
        {
            return $"No puedes completar este paso porque {string.Join(" y ", faltantes)}.";
        }

        if (_esAdmin && _paso.FueTrabajadoPorAuxiliar)
        {
            return $"Antes del cierre administrativo, {string.Join(" y ", faltantes)} del trabajo auxiliar.";
        }

        return null;
    }

    private static string NormalizarEstado(string? estado)
    {
        if (string.IsNullOrWhiteSpace(estado))
        {
            return "pendiente";
        }

        return estado.Trim().ToLowerInvariant() switch
        {
            "enproceso" => "en_proceso",
            "en proceso" => "en_proceso",
            _ => estado.Trim().ToLowerInvariant()
        };
    }

    private static string FormatearTamano(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    private static string TituloTipoCarga(string? tipoCarga) => tipoCarga switch
    {
        "recibidos" => "Recibidos",
        _ => "Emitidos"
    };

    private static string ObtenerClaveColumnaImpuesto(XmlFacturaImpuestoDto impuesto)
        => $"{TituloTipoImpuesto(impuesto.Tipo)}|{impuesto.NombreImpuesto}";

    private static string EtiquetaColumnaImpuesto(string clave)
    {
        var parts = clave.Split('|', 2, StringSplitOptions.TrimEntries);
        return parts.Length == 2 ? $"{parts[1]} {parts[0]}" : clave;
    }

    private static decimal ObtenerImporteImpuesto(XmlFacturaDto factura, string clave)
        => (factura.Impuestos ?? new())
            .Where(x => ObtenerClaveColumnaImpuesto(x).Equals(clave, StringComparison.OrdinalIgnoreCase))
            .Sum(x => x.Importe);

    private static string TituloTipoImpuesto(string? tipo)
        => string.Equals(tipo, "retencion", StringComparison.OrdinalIgnoreCase) ? "Ret." : "Tras.";

    private static bool EsEgreso(XmlFacturaDto factura)
        => string.Equals(factura.Tipo, "egreso", StringComparison.OrdinalIgnoreCase);

    private static string EtiquetaCategoriaFactura(XmlFacturaDto factura)
        => EtiquetaCategoria(factura.CategoriaGastoXml);

    private static string EtiquetaCategoria(string? categoria)
        => categoria switch
        {
            "NoDeducible" => "No deducible",
            "DeduccionPersonal" => "Deduccion personal",
            "Inversion" => "Inversion",
            null or "" => "Sin categoria",
            _ => categoria
        };

    private static string ResumenImpuestosFactura(FacturaCategoriaDraft factura)
        => factura.Impuestos.Count == 0
            ? "-"
            : string.Join(" Â· ", factura.Impuestos
                .GroupBy(x => $"{x.NombreImpuesto} {TituloTipoImpuesto(x.Tipo)}")
                .Select(x => $"{x.Key}: {x.Sum(y => y.Importe):N2}"));

