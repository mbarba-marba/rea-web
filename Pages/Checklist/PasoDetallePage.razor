@page "/checklists/{ChecklistId:long}/paso/{PasoId:long}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin,auxiliar")]
@inject ChecklistService ChecklistService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:20px;align-items:flex-start;gap:16px;">
        <div class="page-header-left">
            <h1>@_titulo</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Captura operativa, notas y evidencias del paso actual.</p>
        </div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <GlassButton Variant="secondary" OnClick="VolverAChecklist">
                <LucideIcon Name="arrow-left" Size="16" /> Volver al checklist
            </GlassButton>
        </div>
    </div>

    @if (_error != null)
    {
        <ErrorBanner Message="@_error" OnDismiss="() => _error = null" />
    }
    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else if (_paso != null)
    {
        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:16px;">
            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Paso</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_paso.NumeroPaso</div>
                <div class="body-small text-muted" style="margin-top:4px;">de 14 pasos del flujo mensual</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Estado</div>
                <div style="margin-bottom:8px;"><BadgeEstado Estado="@EstadoActual" /></div>
                <div class="body-small text-muted">Actualiza el estado segun el avance real.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Evidencias</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_evidencias.Count</div>
                <div class="body-small text-muted" style="margin-top:4px;">Archivos adjuntos a este paso.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Checklist</div>
                <div style="font-size:18px;font-weight:700;color:var(--text-primary);">#@ChecklistId</div>
                <div class="body-small text-muted" style="margin-top:4px;">@(_checklist?.ClienteNombre ?? "Sin cliente") · @(_checklist?.PeriodoNombre ?? "Sin periodo")</div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:minmax(0,1.25fr) minmax(320px,0.85fr);gap:16px;align-items:start;">
            <div style="display:grid;gap:16px;">
                <div class="card" style="padding:0;overflow:hidden;">
                    <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                        <div>
                            <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Contexto</div>
                            <h3 style="margin-top:4px;">Informacion del paso</h3>
                        </div>
                        <div class="body-small text-muted">Paso @_paso.NumeroPaso del flujo mensual.</div>
                    </div>

                    <div style="padding:18px 20px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;">
                        <div class="card" style="padding:14px 16px;">
                            <div class="body-small text-muted">Nombre del paso</div>
                            <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@_subtitulo</div>
                        </div>

                        <div class="card" style="padding:14px 16px;">
                            <div class="body-small text-muted">Cliente y periodo</div>
                            <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@(_checklist?.ClienteNombre ?? "-")</div>
                            <div class="body-small text-muted" style="margin-top:4px;">@(_checklist?.PeriodoNombre ?? "-")</div>
                        </div>

                        <div class="card" style="padding:14px 16px;">
                            <div class="body-small text-muted">Ultima marca de completado</div>
                            <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@(_paso.CompletadoEn?.ToString("dd/MM/yyyy HH:mm") ?? "Sin completar aun")</div>
                        </div>

                        <div class="card" style="padding:14px 16px;">
                            <div class="body-small text-muted">Estado actual</div>
                            <div style="margin-top:8px;"><BadgeEstado Estado="@EstadoActual" /></div>
                        </div>
                    </div>
                </div>

                <div class="card" style="padding:0;overflow:hidden;">
                    <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                        <div>
                            <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Captura</div>
                            <h3 style="margin-top:4px;">Notas del paso</h3>
                        </div>
                        <div class="body-small text-muted">Documenta hallazgos, pendientes y contexto operativo.</div>
                    </div>

                    <div style="padding:18px 20px;display:grid;gap:14px;">
                        <div>
                            <label class="input-label">Notas operativas</label>
                            <textarea @bind="_notas"
                                      @bind:event="oninput"
                                      class="input-field"
                                      rows="6"
                                      style="width:100%;resize:vertical;min-height:144px;"
                                      placeholder="Describe que se reviso, pendientes encontrados, dependencias o aclaraciones para el siguiente movimiento."></textarea>
                        </div>

                        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                            <GlassButton Variant="primary" OnClick="GuardarNotas" Disabled="@_guardando">
                                <LucideIcon Name="save" Size="16" /> @(_guardando ? "Guardando..." : "Guardar notas")
                            </GlassButton>

                            @if (EstadoActual == "pendiente")
                            {
                                <GlassButton Variant="primary" OnClick="CompletarPaso" Disabled="@(!PuedeCompletarPaso)">
                                    <LucideIcon Name="check" Size="16" /> Completar
                                </GlassButton>
                            }
                            else if (EstadoActual == "en_proceso")
                            {
                                <GlassButton Variant="primary" OnClick="CompletarPaso" Disabled="@(!PuedeCompletarPaso)">
                                    <LucideIcon Name="check" Size="16" /> Completar
                                </GlassButton>
                                <GlassButton Variant="secondary" OnClick="BloquearPaso">
                                    <LucideIcon Name="pause-circle" Size="16" /> Bloquear
                                </GlassButton>
                            }
                            else if (EstadoActual == "bloqueado")
                            {
                                <GlassButton Variant="secondary" OnClick="DesbloquearPaso">
                                    <LucideIcon Name="rotate-ccw" Size="16" /> Desbloquear
                                </GlassButton>
                                <GlassButton Variant="primary" OnClick="CompletarPaso" Disabled="@(!PuedeCompletarPaso)">
                                    <LucideIcon Name="check" Size="16" /> Completar
                                </GlassButton>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(MensajeBloqueoCompletar))
                        {
                            <div style="display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border-radius:14px;background:rgba(245,158,11,0.10);border:1px solid rgba(245,158,11,0.18);color:#b45309;">
                                <LucideIcon Name="alert-circle" Size="18" />
                                <span style="font-size:13px;font-weight:600;">@MensajeBloqueoCompletar</span>
                            </div>
                        }

                        @if (_mensaje != null)
                        {
                            <div style="display:flex;align-items:center;gap:8px;color:var(--success);font-size:13px;font-weight:600;">
                                <LucideIcon Name="badge-check" Size="16" />
                                <span>@_mensaje</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div style="display:grid;gap:16px;">
                @if (_paso.Protocolo?.TieneReglasActivas == true)
                {
                    <div class="card" style="padding:18px 20px;">
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Protocolo activo</div>
                        <h3 style="margin-top:4px;">Candados para trabajo auxiliar</h3>
                        <div style="display:grid;gap:10px;margin-top:14px;">
                            @if (_paso.Protocolo.NotaObligatoriaAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="notebook-pen" Size="16" />
                                    <span class="body-small">Se requiere nota operativa antes de completar.</span>
                                </div>
                            }
                            @if (_paso.Protocolo.EvidenciaObligatoriaAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="paperclip" Size="16" />
                                    <span class="body-small">Se requiere al menos una evidencia adjunta.</span>
                                </div>
                            }
                            @if (_paso.Protocolo.RequiereCierreAdminAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="shield-check" Size="16" />
                                    <span class="body-small">El cierre final de este paso solo puede hacerlo un administrador.</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="card" style="padding:0;overflow:hidden;">
                    <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                        <div>
                            <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Documentacion</div>
                            <h3 style="margin-top:4px;">Evidencias</h3>
                        </div>
                        <div class="body-small text-muted">@_evidencias.Count archivo(s)</div>
                    </div>

                    <div style="padding:18px 20px;display:grid;gap:14px;">
                        @if (_evidencias.Count == 0)
                        {
                            <div class="card empty-state" style="padding:28px 18px;">
                                <LucideIcon Name="file-stack" Size="28" />
                                <div class="empty-state-heading" style="font-size:16px;">Sin evidencias adjuntas</div>
                                <div class="empty-state-body">Sube documentos de respaldo para dejar trazabilidad del paso.</div>
                            </div>
                        }
                        else
                        {
                            <div style="display:grid;gap:10px;max-height:360px;overflow-y:auto;padding-right:2px;">
                                @foreach (var evidencia in _evidencias.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div class="card" style="padding:14px 16px;">
                                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                                            <div style="min-width:0;">
                                                <div style="font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@evidencia.NombreArchivo</div>
                                                <div class="body-small text-muted" style="margin-top:4px;">@FormatearTamano(evidencia.TamanoBytes) · @evidencia.CreatedAt.ToString("dd/MM/yy HH:mm")</div>
                                            </div>
                                            <a href="https://rea-interno-production.up.railway.app/api/v1/checklists/evidencias/@evidencia.EvidenciaId/descargar"
                                               class="btn btn-secondary btn-icon"
                                               target="_blank"
                                               title="Descargar evidencia">
                                                <LucideIcon Name="download" Size="15" />
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="card" style="padding:14px 16px;">
                            <div class="body-small text-muted" style="margin-bottom:10px;">Adjuntar documento</div>
                            <InputFile OnChange="OnArchivoSeleccionado" class="input-field" />

                            @if (_archivo != null)
                            {
                                <div style="margin-top:10px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;">
                                    <div>
                                        <div style="font-weight:600;color:var(--text-primary);">@_archivoNombre</div>
                                        <div class="body-small text-muted" style="margin-top:4px;">Listo para subir al expediente.</div>
                                    </div>
                                    <GlassButton Variant="primary" OnClick="SubirEvidencia" Disabled="@_subiendo">
                                        <LucideIcon Name="upload" Size="16" /> @(_subiendo ? "Subiendo..." : "Subir archivo")
                                    </GlassButton>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="card" style="padding:18px 20px;">
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Navegacion</div>
                    <h3 style="margin-top:4px;">Siguiente contexto</h3>
                    <p class="body-small text-muted" style="margin-top:8px;">Vuelve al checklist para revisar el avance completo o continua con el siguiente paso operativo.</p>

                    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;">
                        <GlassButton Variant="secondary" OnClick="VolverAChecklist">
                            <LucideIcon Name="layout-list" Size="16" /> Ver checklist
                        </GlassButton>
                        @if (_siguientePaso != null)
                        {
                            <GlassButton Variant="primary" OnClick="AbrirSiguientePaso">
                                <LucideIcon Name="arrow-right" Size="16" /> Abrir paso @_siguientePaso.NumeroPaso
                            </GlassButton>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public long ChecklistId { get; set; }
    [Parameter] public long PasoId { get; set; }

    private readonly List<BreadcrumbItem> _breadcrumb = new()
    {
        new() { Text = "Inicio", Url = "/" },
        new() { Text = "Checklists", Url = "/checklists" },
        new() { Text = "Checklist", Url = "#" },
        new() { Text = "Paso", Url = "#" }
    };

    private ChecklistDto? _checklist;
    private PasoDto? _paso;
    private PasoDto? _siguientePaso;
    private List<EvidenciaDto> _evidencias = new();
    private string _titulo = "Paso";
    private string _subtitulo = "";
    private string _notas = "";
    private bool _cargando = true;
    private bool _guardando;
    private bool _subiendo;
    private string? _error;
    private string? _mensaje;
    private string? _archivoNombre;
    private IBrowserFile? _archivo;
    private bool _esAdmin;
    private bool _esAuxiliar;
    private string EstadoActual => NormalizarEstado(_paso?.Estado);
    private bool TieneNotaOperativa => !string.IsNullOrWhiteSpace(_notas);
    private bool TieneEvidencias => _evidencias.Count > 0;
    private bool PuedeCompletarPaso => string.IsNullOrWhiteSpace(MensajeBloqueoCompletar);
    private string? MensajeBloqueoCompletar => ObtenerMensajeBloqueoCompletar();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _esAdmin = authState.User.IsInRole("admin") ||
                   string.Equals(authState.User.FindFirst(ClaimTypes.Role)?.Value, "admin", StringComparison.OrdinalIgnoreCase);
        _esAuxiliar = authState.User.IsInRole("auxiliar") ||
                      string.Equals(authState.User.FindFirst(ClaimTypes.Role)?.Value, "auxiliar", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnParametersSetAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;

        try
        {
            var result = await ChecklistService.ObtenerAsync(ChecklistId);
            if (result?.Ok == true && result.Data != null)
            {
                _checklist = result.Data;
                _paso = result.Data.Pasos.FirstOrDefault(p => p.PasoId == PasoId);

                if (_paso != null)
                {
                    _evidencias = _paso.Evidencias ?? new();
                    _notas = _paso.Notas ?? "";
                    _titulo = $"Paso {_paso.NumeroPaso}";
                    _subtitulo = _paso.NombrePaso ?? "";
                    _siguientePaso = ObtenerSiguientePaso(result.Data.Pasos, _paso);

                    _breadcrumb[2] = new BreadcrumbItem { Text = _checklist.ClienteNombre, Url = $"/checklists/{ChecklistId}" };
                    _breadcrumb[3] = new BreadcrumbItem { Text = _titulo, Url = $"/checklists/{ChecklistId}/paso/{PasoId}" };
                }
                else
                {
                    _error = "Paso no encontrado";
                }
            }
            else
            {
                _error = result?.Error?.Message ?? "Error al cargar el paso";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _cargando = false;
    }

    private async Task GuardarNotas()
    {
        if (_paso == null)
        {
            return;
        }

        _guardando = true;
        var response = await ChecklistService.ActualizarPasoAsync(ChecklistId, PasoId, new UpdatePasoRequest
        {
            Notas = _notas,
            Estado = EstadoActual
        });

        if (response?.Ok == true)
        {
            _mensaje = "Notas guardadas correctamente.";
            await Cargar();
        }
        else
        {
            _error = response?.Error?.Message;
        }

        _guardando = false;
    }

    private async Task CompletarPaso() => await Cambiar("completado");
    private async Task BloquearPaso() => await Cambiar("bloqueado");
    private async Task DesbloquearPaso() => await Cambiar("en_proceso");

    private async Task Cambiar(string estado)
    {
        var response = await ChecklistService.ActualizarPasoAsync(ChecklistId, PasoId, new UpdatePasoRequest
        {
            Estado = estado,
            Notas = _notas
        });

        if (response?.Ok == true)
        {
            _mensaje = estado switch
            {
                "completado" => "Paso completado.",
                "bloqueado" => "Paso bloqueado.",
                "en_proceso" => "Paso reactivado.",
                _ => "Paso actualizado."
            };
            await Cargar();
        }
        else
        {
            _error = response?.Error?.Message;
        }
    }

    private async Task OnArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        if (e.FileCount > 0)
        {
            _archivo = e.File;
            _archivoNombre = e.File.Name;
        }
        else
        {
            _archivo = null;
            _archivoNombre = null;
        }

        await Task.CompletedTask;
    }

    private async Task SubirEvidencia()
    {
        if (_archivo == null)
        {
            return;
        }

        _subiendo = true;

        try
        {
            using var content = new MultipartFormDataContent();
            var stream = _archivo.OpenReadStream(25 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_archivo.ContentType);
            content.Add(fileContent, "archivo", _archivo.Name);

            var response = await Http.PostAsync($"api/v1/checklists/{ChecklistId}/pasos/{PasoId}/evidencias", content);
            if (response.IsSuccessStatusCode)
            {
                _archivo = null;
                _archivoNombre = null;
                _mensaje = "Evidencia subida correctamente.";
                await Cargar();
            }
            else
            {
                _error = "Error al subir la evidencia";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _subiendo = false;
    }

    private void VolverAChecklist() => Navigation.NavigateTo($"/checklists/{ChecklistId}");

    private void AbrirSiguientePaso()
    {
        if (_siguientePaso == null)
        {
            return;
        }

        Navigation.NavigateTo($"/checklists/{ChecklistId}/paso/{_siguientePaso.PasoId}");
    }

    private static PasoDto? ObtenerSiguientePaso(IEnumerable<PasoDto> pasos, PasoDto actual)
    {
        var lista = pasos.OrderBy(p => p.NumeroPaso).ToList();

        var siguienteDespues = lista.FirstOrDefault(p =>
            p.NumeroPaso > actual.NumeroPaso &&
            NormalizarEstado(p.Estado) != "completado");

        if (siguienteDespues != null)
        {
            return siguienteDespues;
        }

        return lista.FirstOrDefault(p =>
            p.PasoId != actual.PasoId &&
            NormalizarEstado(p.Estado) != "completado");
    }

    private string? ObtenerMensajeBloqueoCompletar()
    {
        if (_paso?.Protocolo == null || !_paso.Protocolo.TieneReglasActivas)
        {
            return null;
        }

        if (_esAuxiliar && _paso.Protocolo.RequiereCierreAdminAuxiliar)
        {
            return "Este paso debe cerrarlo un administrador, aunque el checklist este asignado a tu cartera.";
        }

        var faltantes = new List<string>();
        if (_paso.Protocolo.NotaObligatoriaAuxiliar && !TieneNotaOperativa)
        {
            faltantes.Add("falta la nota obligatoria");
        }

        if (_paso.Protocolo.EvidenciaObligatoriaAuxiliar && !TieneEvidencias)
        {
            faltantes.Add("falta la evidencia obligatoria");
        }

        if (faltantes.Count == 0)
        {
            return null;
        }

        if (_esAuxiliar)
        {
            return $"No puedes completar este paso porque {string.Join(" y ", faltantes)}.";
        }

        if (_esAdmin && _paso.FueTrabajadoPorAuxiliar)
        {
            return $"Antes del cierre administrativo, {string.Join(" y ", faltantes)} del trabajo auxiliar.";
        }

        return null;
    }

    private static string NormalizarEstado(string? estado)
    {
        if (string.IsNullOrWhiteSpace(estado))
        {
            return "pendiente";
        }

        return estado.Trim().ToLowerInvariant() switch
        {
            "enproceso" => "en_proceso",
            "en proceso" => "en_proceso",
            _ => estado.Trim().ToLowerInvariant()
        };
    }

    private static string FormatearTamano(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
