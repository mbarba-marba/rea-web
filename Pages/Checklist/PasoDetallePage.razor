@page "/checklists/{ChecklistId:long}/paso/{PasoId:long}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin,auxiliar")]
@inject ChecklistService ChecklistService
@inject XmlService XmlService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:20px;align-items:flex-start;gap:16px;">
        <div class="page-header-left">
            <h1>@_titulo</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Captura operativa, notas y evidencias del paso actual.</p>
        </div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <GlassButton Variant="secondary" OnClick="VolverAChecklist">
                <LucideIcon Name="arrow-left" Size="16" /> Volver al checklist
            </GlassButton>
        </div>
    </div>

    @if (_error != null)
    {
        <ErrorBanner Message="@_error" OnDismiss="() => _error = null" />
    }
    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else if (_paso != null)
    {
        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:16px;">
            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Paso</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_paso.NumeroPaso</div>
                <div class="body-small text-muted" style="margin-top:4px;">de 14 pasos del flujo mensual</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Estado</div>
                <div style="margin-bottom:8px;"><BadgeEstado Estado="@EstadoActual" /></div>
                <div class="body-small text-muted">Actualiza el estado segun el avance real.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">@(EsPasoXml ? "Egresos sin categoria" : "Evidencias")</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@(EsPasoXml ? FacturasSinCategoria.Count : _evidencias.Count)</div>
                <div class="body-small text-muted" style="margin-top:4px;">@(EsPasoXml ? "No entran a ISR/IVA hasta que alguien los clasifique." : "Archivos adjuntos a este paso.")</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Checklist</div>
                <div style="font-size:18px;font-weight:700;color:var(--text-primary);">#@ChecklistId</div>
                <div class="body-small text-muted" style="margin-top:4px;">@(_checklist?.ClienteNombre ?? "Sin cliente") Â· @(_checklist?.PeriodoNombre ?? "Sin periodo")</div>
            </div>
        </div>

        @* ── Fila superior: Contexto + Navegacion (misma altura) ── *@
        <div style="display:grid;grid-template-columns:minmax(0,1.25fr) minmax(320px,0.85fr);gap:16px;align-items:stretch;margin-bottom:16px;">

            @* LEFT: Contexto *@
            <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column;">
                <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Contexto</div>
                        <h3 style="margin-top:4px;">Informacion del paso</h3>
                    </div>
                    <div class="body-small text-muted">Paso @_paso.NumeroPaso del flujo mensual.</div>
                </div>

                <div style="padding:18px 20px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;flex:1;align-content:start;">
                    <div class="card" style="padding:14px 16px;">
                        <div class="body-small text-muted">Nombre del paso</div>
                        <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@_subtitulo</div>
                    </div>

                    <div class="card" style="padding:14px 16px;">
                        <div class="body-small text-muted">Cliente y periodo</div>
                        <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@(_checklist?.ClienteNombre ?? "-")</div>
                        <div class="body-small text-muted" style="margin-top:4px;">@(_checklist?.PeriodoNombre ?? "-")</div>
                    </div>

                    <div class="card" style="padding:14px 16px;">
                        <div class="body-small text-muted">Ultima marca de completado</div>
                        <div style="font-weight:700;color:var(--text-primary);margin-top:6px;">@(_paso.CompletadoEn?.ToString("dd/MM/yyyy HH:mm") ?? "Sin completar aun")</div>
                    </div>

                    <div class="card" style="padding:14px 16px;">
                        <div class="body-small text-muted">Estado actual</div>
                        <div style="margin-top:8px;"><BadgeEstado Estado="@EstadoActual" /></div>
                    </div>
                </div>
            </div>

            @* RIGHT: Protocolo + Navegacion *@
            <div style="display:grid;gap:16px;align-content:start;">
                @if (_paso.Protocolo?.TieneReglasActivas == true)
                {
                    <div class="card" style="padding:18px 20px;">
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Protocolo activo</div>
                        <h3 style="margin-top:4px;">Candados para trabajo auxiliar</h3>
                        <div style="display:grid;gap:10px;margin-top:14px;">
                            @if (_paso.Protocolo.NotaObligatoriaAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="notebook-pen" Size="16" />
                                    <span class="body-small">Se requiere nota operativa antes de completar.</span>
                                </div>
                            }
                            @if (_paso.Protocolo.EvidenciaObligatoriaAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="paperclip" Size="16" />
                                    <span class="body-small">Se requiere al menos una evidencia adjunta.</span>
                                </div>
                            }
                            @if (_paso.Protocolo.RequiereCierreAdminAuxiliar)
                            {
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <LucideIcon Name="shield-check" Size="16" />
                                    <span class="body-small">El cierre final de este paso solo puede hacerlo un administrador.</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="card" style="padding:18px 20px;">
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Navegacion</div>
                    <h3 style="margin-top:4px;">Siguiente contexto</h3>
                    <p class="body-small text-muted" style="margin-top:8px;">Vuelve al checklist para revisar el avance completo o continua con el siguiente paso operativo.</p>

                    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;">
                        <GlassButton Variant="secondary" OnClick="VolverAChecklist">
                            <LucideIcon Name="layout-list" Size="16" /> Ver checklist
                        </GlassButton>
                        @if (_siguientePaso != null)
                        {
                            <GlassButton Variant="primary" OnClick="AbrirSiguientePaso">
                                <LucideIcon Name="arrow-right" Size="16" /> Abrir paso @_siguientePaso.NumeroPaso
                            </GlassButton>
                        }
                    </div>
                </div>

                @if (EsPasoXml)
                {
                    <div class="card" style="padding:18px 20px;">
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Alcance XML</div>
                        <h3 style="margin-top:4px;">Solo este checklist</h3>
                        <p class="body-small text-muted" style="margin-top:8px;">Aqui solo se muestran las cargas y facturas subidas desde este paso 2. No mezclamos historicos del cliente para mantener el expediente limpio y controlable.</p>
                        <div style="display:grid;gap:8px;margin-top:14px;">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <LucideIcon Name="folder-lock" Size="16" />
                                <span class="body-small">Cargas aisladas por checklist actual.</span>
                            </div>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <LucideIcon Name="trash-2" Size="16" />
                                <span class="body-small">Puedes depurar XML individuales sin tocar historicos ajenos.</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── Secciones anchas (ancho total) ── *@
        <div style="display:grid;gap:16px;">

                @if (EsPasoXml)
                {
                    <div class="card" style="padding:0;overflow:hidden;">
                        <div class="surface-panel-header" style="padding:16px 20px;display:grid;gap:6px;">
                            <div>
                                <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Paso 2</div>
                                <h3 style="margin-top:4px;">Carga XML emitidos y recibidos</h3>
                            </div>
                            <div class="body-small text-muted">Aqui solo se ven las cargas realizadas dentro de este checklist. Cliente y periodo ya quedaron resueltos por el expediente actual.</div>
                        </div>

                        <div style="padding:18px 20px;display:grid;gap:14px;">
                            <div style="display:grid;grid-template-columns:repeat(2,minmax(320px,1fr));gap:14px;">
                                <div class="card" style="padding:16px;">
                                    <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">XML Emitidos</div>
                                    <div class="body-small text-muted">Sube un ZIP o RAR con los CFDI emitidos del periodo.</div>
                                    <div style="margin-top:12px;display:grid;gap:10px;">
                                        <InputFile OnChange="OnArchivoEmitidosSeleccionado" class="input-field" accept=".zip,.rar" />
                                        @if (_archivoEmitidos != null)
                                        {
                                            <div class="body-small text-muted">@_archivoEmitidosNombre</div>
                                        }
                                        <GlassButton Variant="primary" OnClick="SubirXmlEmitidos" Disabled="@(_subiendoEmitidos || _archivoEmitidos == null)">
                                            <LucideIcon Name="upload" Size="16" /> @(_subiendoEmitidos ? "Subiendo..." : "Procesar emitidos")
                                        </GlassButton>
                                    </div>
                                </div>

                                <div class="card" style="padding:16px;">
                                    <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">XML Recibidos</div>
                                    <div class="body-small text-muted">Sube un ZIP o RAR con los CFDI recibidos del periodo.</div>
                                    <div style="margin-top:12px;display:grid;gap:10px;">
                                        <InputFile OnChange="OnArchivoRecibidosSeleccionado" class="input-field" accept=".zip,.rar" />
                                        @if (_archivoRecibidos != null)
                                        {
                                            <div class="body-small text-muted">@_archivoRecibidosNombre</div>
                                        }
                                        <GlassButton Variant="primary" OnClick="SubirXmlRecibidos" Disabled="@(_subiendoRecibidos || _archivoRecibidos == null)">
                                            <LucideIcon Name="upload" Size="16" /> @(_subiendoRecibidos ? "Subiendo..." : "Procesar recibidos")
                                        </GlassButton>
                                    </div>
                                </div>
                            </div>

                            <div class="card" style="padding:14px 16px;">
                                <div class="body-small text-muted">Historial del paso</div>
                                @if (_xmlCargasPaso.Count == 0)
                                {
                                    <div class="empty-state" style="padding:24px 18px;">
                                        <LucideIcon Name="archive-x" Size="28" />
                                        <div class="empty-state-heading" style="font-size:16px;">Sin cargas XML</div>
                                        <div class="empty-state-body">Aun no hay emitidos ni recibidos registrados dentro de este checklist.</div>
                                    </div>
                                }
                                else
                                {
                                    <div style="display:grid;gap:10px;max-height:360px;overflow-y:auto;padding-right:2px;margin-top:10px;">
                                        @foreach (var carga in _xmlCargasPaso.OrderByDescending(x => x.CreatedAt))
                                        {
                                            <div class="card" style="padding:14px 16px;">
                                                <div style="display:grid;grid-template-columns:minmax(0,1fr) auto;gap:14px;align-items:start;">
                                                    <div style="min-width:0;display:grid;gap:10px;">
                                                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                                            <span class="badge @(carga.TipoCarga == "emitidos" ? "badge-accent" : "badge-muted")">@TituloTipoCarga(carga.TipoCarga)</span>
                                                            <div style="font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(!string.IsNullOrWhiteSpace(carga.NombreArchivo) ? carga.NombreArchivo : carga.NombreZip)</div>
                                                        </div>
                                                        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;">
                                                            <div class="card" style="padding:10px 12px;">
                                                                <div class="body-small text-muted">Subido</div>
                                                                <div style="font-weight:600;color:var(--text-primary);margin-top:4px;">@carga.CreatedAt.ToString("dd/MM/yy HH:mm")</div>
                                                            </div>
                                                            <div class="card" style="padding:10px 12px;">
                                                                <div class="body-small text-muted">Procesados</div>
                                                                <div style="font-weight:700;color:var(--text-primary);margin-top:4px;">@carga.Procesados</div>
                                                            </div>
                                                            <div class="card" style="padding:10px 12px;">
                                                                <div class="body-small text-muted">Errores</div>
                                                                <div style="font-weight:700;color:var(--text-primary);margin-top:4px;">@carga.ConErrores</div>
                                                            </div>
                                                        </div>
                                                        @if (!string.IsNullOrWhiteSpace(carga.ErrorMensaje))
                                                        {
                                                            <div style="padding:10px 12px;border-radius:12px;background:rgba(245,158,11,0.10);border:1px solid rgba(245,158,11,0.16);color:#b45309;font-size:12px;white-space:pre-line;">
                                                                @carga.ErrorMensaje
                                                            </div>
                                                        }
                                                    </div>
                                                    <div style="display:flex;justify-content:flex-end;">
                                                        <BadgeEstado Estado="@carga.Estado" />
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="card" style="padding:14px 16px;">
                                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                                    <div>
                                        <div class="body-small text-muted">Facturas extraidas</div>
                                        <div style="font-weight:700;color:var(--text-primary);margin-top:4px;">Desglose fiscal del checklist actual</div>
                                    </div>
                                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
                                        <span class="badge badge-muted">@FacturasSinCategoria.Count sin categoria</span>
                                        <select class="input-field" style="min-width:180px;" @bind="_filtroCategoriaXml">
                                            <option value="todos">Todos los CFDI</option>
                                            <option value="sin_categoria">Solo sin categoria</option>
                                            <option value="categorizados">Solo categorizados</option>
                                        </select>
                                        <GlassButton Variant="secondary" OnClick="AbrirModalCategorias" Disabled="@(FacturasSinCategoria.Count == 0)">
                                            <LucideIcon Name="tags" Size="16" /> Clasificar egresos
                                        </GlassButton>
                                    </div>
                                </div>

                                @if (FacturasFiltradasXml.Count == 0)
                                {
                                    <div class="empty-state" style="padding:24px 18px;">
                                        <LucideIcon Name="receipt-text" Size="28" />
                                        <div class="empty-state-heading" style="font-size:16px;">Sin CFDI en este filtro</div>
                                        <div class="empty-state-body">Ajusta el filtro o carga nuevos XML para revisar el desglose fiscal del periodo.</div>
                                    </div>
                                }
                                else
                                {
                                    <div style="overflow:auto;margin-top:12px;">
                                        <table style="width:100%;border-collapse:collapse;min-width:@($"{980 + (_columnasImpuestoXml.Count * 120)}px");">
                                            <thead>
                                                <tr style="border-bottom:1px solid var(--border-color);">
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Fecha</th>
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">UUID</th>
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Tipo</th>
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Metodo</th>
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Categoria</th>
                                                    <th style="text-align:left;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Complementos</th>
                                                    @foreach (var columna in _columnasImpuestoXml)
                                                    {
                                                        <th style="text-align:right;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">@EtiquetaColumnaImpuesto(columna)</th>
                                                    }
                                                    <th style="text-align:right;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Total</th>
                                                    <th style="text-align:right;padding:10px 8px;font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var factura in FacturasFiltradasXml)
                                                {
                                                    <tr style="border-bottom:1px solid var(--border-color);">
                                                        <td style="padding:12px 8px;color:var(--text-primary);white-space:nowrap;">@factura.FechaEmision.ToString("dd/MM/yyyy")</td>
                                                        <td style="padding:12px 8px;color:var(--text-primary);min-width:180px;">
                                                            <div style="font-weight:600;">@factura.Uuid</div>
                                                            <div class="body-small text-muted" style="margin-top:4px;">@factura.RfcEmisor â†’ @factura.RfcReceptor</div>
                                                        </td>
                                                        <td style="padding:12px 8px;color:var(--text-primary);white-space:nowrap;">@factura.Tipo.ToUpperInvariant()</td>
                                                        <td style="padding:12px 8px;color:var(--text-primary);white-space:nowrap;">@(string.IsNullOrWhiteSpace(factura.MetodoPago) ? "-" : factura.MetodoPago)</td>
                                                        <td style="padding:12px 8px;color:var(--text-primary);white-space:nowrap;">
                                                            @if (EsEgreso(factura))
                                                            {
                                                                <span class="badge @(string.IsNullOrWhiteSpace(factura.CategoriaGastoXml) ? "badge-muted" : "badge-accent")">@EtiquetaCategoriaFactura(factura)</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="body-small text-muted">-</span>
                                                            }
                                                        </td>
                                                        <td style="padding:12px 8px;color:var(--text-primary);min-width:160px;">
                                                            @(factura.TieneComplemento
                                                                ? (!string.IsNullOrWhiteSpace(factura.ComplementosDetectados) ? factura.ComplementosDetectados : "Complemento detectado")
                                                                : "-")
                                                        </td>
                                                        @foreach (var columna in _columnasImpuestoXml)
                                                        {
                                                            var importe = ObtenerImporteImpuesto(factura, columna);
                                                            <td style="padding:12px 8px;text-align:right;color:var(--text-primary);white-space:nowrap;">@(importe == 0 ? "-" : importe.ToString("N2"))</td>
                                                        }
                                                        <td style="padding:12px 8px;text-align:right;color:var(--text-primary);font-weight:700;white-space:nowrap;">@factura.Total.ToString("N2")</td>
                                                        <td style="padding:12px 8px;text-align:right;white-space:nowrap;">
                                                            @if (_facturaPendienteEliminarId == factura.FacturaId)
                                                            {
                                                                <div style="display:inline-flex;gap:8px;align-items:center;">
                                                                    <button class="btn btn-secondary btn-sm" @onclick="CancelarEliminarFactura" disabled="@_eliminandoFactura">Cancelar</button>
                                                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarFactura(factura.FacturaId)" disabled="@_eliminandoFactura">
                                                                        @(_eliminandoFactura ? "Eliminando..." : "Confirmar")
                                                                    </button>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <button class="btn btn-secondary btn-icon" title="Eliminar XML del checklist" @onclick="() => SolicitarEliminarFactura(factura.FacturaId)">
                                                                    <LucideIcon Name="trash-2" Size="16" />
                                                                </button>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (!EsPasoXml)
                {
                    <div class="card" style="padding:0;overflow:hidden;">
                        <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                            <div>
                                <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Documentacion</div>
                                <h3 style="margin-top:4px;">Evidencias</h3>
                            </div>
                            <div class="body-small text-muted">@_evidencias.Count archivo(s)</div>
                        </div>

                        <div style="padding:18px 20px;display:grid;gap:14px;">
                            @if (_evidencias.Count == 0)
                            {
                                <div class="card empty-state" style="padding:28px 18px;">
                                    <LucideIcon Name="file-stack" Size="28" />
                                    <div class="empty-state-heading" style="font-size:16px;">Sin evidencias adjuntas</div>
                                    <div class="empty-state-body">Sube documentos de respaldo para dejar trazabilidad del paso.</div>
                                </div>
                            }
                            else
                            {
                                <div style="display:grid;gap:10px;max-height:360px;overflow-y:auto;padding-right:2px;">
                                    @foreach (var evidencia in _evidencias.OrderByDescending(x => x.CreatedAt))
                                    {
                                        <div class="card" style="padding:14px 16px;">
                                            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                                                <div style="min-width:0;">
                                                    <div style="font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@evidencia.NombreArchivo</div>
                                                    <div class="body-small text-muted" style="margin-top:4px;">@FormatearTamano(evidencia.TamanoBytes) &middot; @evidencia.CreatedAt.ToString("dd/MM/yy HH:mm")</div>
                                                </div>
                                                <a href="https://rea-interno-production.up.railway.app/api/v1/checklists/evidencias/@evidencia.EvidenciaId/descargar"
                                                   class="btn btn-secondary btn-icon"
                                                   target="_blank"
