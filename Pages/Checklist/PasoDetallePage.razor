@code {
    [Parameter] public long ChecklistId { get; set; }
    [Parameter] public long PasoId { get; set; }

    private readonly List<BreadcrumbItem> _breadcrumb = new()
    {
        new() { Text = "Inicio", Url = "/" },
        new() { Text = "Checklists", Url = "/checklists" },
        new() { Text = "Checklist", Url = "#" },
        new() { Text = "Paso", Url = "#" }
    };

    private ChecklistDto? _checklist;
    private PasoDto? _paso;
    private PasoDto? _siguientePaso;
    private List<EvidenciaDto> _evidencias = new();
    private List<XmlCargaDto> _xmlCargasPaso = new();
    private List<XmlFacturaDto> _facturasXmlPaso = new();
    private List<string> _columnasImpuestoXml = new();
    private List<FacturaCategoriaDraft> _pendientesCategoria = new();
    private string _titulo = "Paso";
    private string _subtitulo = "";
    private string _notas = "";
    private bool _cargando = true;
    private bool _guardando;
    private bool _subiendo;
    private string? _error;
    private string? _mensaje;
    private string? _archivoNombre;
    private IBrowserFile? _archivo;
    private string? _archivoEmitidosNombre;
    private IBrowserFile? _archivoEmitidos;
    private string? _archivoRecibidosNombre;
    private IBrowserFile? _archivoRecibidos;
    private bool _subiendoEmitidos;
    private bool _subiendoRecibidos;
    private bool _modalCategoriasVisible;
    private bool _guardandoCategorias;
    private long? _facturaPendienteEliminarId;
    private bool _eliminandoFactura;
    private bool _esAdmin;
    private bool _esAuxiliar;
    private string _filtroCategoriaXml = "todos";
    private string? _categoriaLote;
    private bool EsPasoXml => _paso?.NumeroPaso == 2;
    private string EstadoActual => NormalizarEstado(_paso?.Estado);
    private bool TieneNotaOperativa => !string.IsNullOrWhiteSpace(_notas);
    private bool TieneEvidencias => EsPasoXml ? _xmlCargasPaso.Count > 0 : _evidencias.Count > 0;
    private bool PuedeCompletarPaso => string.IsNullOrWhiteSpace(MensajeBloqueoCompletar);
    private string? MensajeBloqueoCompletar => ObtenerMensajeBloqueoCompletar();
    private IReadOnlyList<XmlFacturaDto> FacturasSinCategoria => _facturasXmlPaso
        .Where(x => EsEgreso(x) && string.IsNullOrWhiteSpace(x.CategoriaGastoXml))
        .ToList();
    private IReadOnlyList<XmlFacturaDto> FacturasFiltradasXml => _filtroCategoriaXml switch
    {
        "sin_categoria" => _facturasXmlPaso.Where(x => EsEgreso(x) && string.IsNullOrWhiteSpace(x.CategoriaGastoXml)).ToList(),
        "categorizados" => _facturasXmlPaso.Where(x => !EsEgreso(x) || !string.IsNullOrWhiteSpace(x.CategoriaGastoXml)).ToList(),
        _ => _facturasXmlPaso
    };
    private readonly (string Value, string Label)[] _opcionesCategoriasGasto =
    [
        ("Compra", "Compra"),
        ("Gasto", "Gasto"),
        ("NoDeducible", "No deducible"),
        ("Inversion", "Inversion"),
        ("DeduccionPersonal", "Deduccion personal"),
        ("Restaurante", "Restaurante")
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _esAdmin = authState.User.IsInRole("admin") ||
                   string.Equals(authState.User.FindFirst(ClaimTypes.Role)?.Value, "admin", StringComparison.OrdinalIgnoreCase);
        _esAuxiliar = authState.User.IsInRole("auxiliar") ||
                      string.Equals(authState.User.FindFirst(ClaimTypes.Role)?.Value, "auxiliar", StringComparison.OrdinalIgnoreCase);
    }

    protected override async Task OnParametersSetAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _error = null;

        try
        {
            var result = await ChecklistService.ObtenerAsync(ChecklistId);
            if (result?.Ok == true && result.Data != null)
            {
                _checklist = result.Data;
                _paso = result.Data.Pasos.FirstOrDefault(p => p.PasoId == PasoId);

                if (_paso != null)
                {
                    _evidencias = _paso.Evidencias ?? new();
                    _xmlCargasPaso = new();
                    _notas = _paso.Notas ?? "";
                    _titulo = $"Paso {_paso.NumeroPaso}";
                    _subtitulo = _paso.NombrePaso ?? "";
                    _siguientePaso = ObtenerSiguientePaso(result.Data.Pasos, _paso);

                    _breadcrumb[2] = new BreadcrumbItem { Text = _checklist.ClienteNombre, Url = $"/checklists/{ChecklistId}" };
                    _breadcrumb[3] = new BreadcrumbItem { Text = _titulo, Url = $"/checklists/{ChecklistId}/paso/{PasoId}" };

                    if (EsPasoXml)
                    {
                        await CargarXmlPasoAsync();
                    }
                }
                else
                {
                    _error = "Paso no encontrado";
                }
            }
            else
            {
                _error = result?.Error?.Message ?? "Error al cargar el paso";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _cargando = false;
    }

    private async Task CargarXmlPasoAsync()
    {
        if (_checklist == null || !EsPasoXml)
        {
            _xmlCargasPaso = new();
            _facturasXmlPaso = new();
            _columnasImpuestoXml = new();
            return;
        }

        try
        {
            var result = await XmlService.ListarCargasPorChecklistAsync(ChecklistId, page: 1, limit: 100);
            if (result?.Ok == true)
            {
                _xmlCargasPaso = (result.Data ?? new())
                    .Where(x => x.TipoCarga is "emitidos" or "recibidos")
                    .OrderByDescending(x => x.CreatedAt)
                    .ToList();
            }
            else
            {
                _xmlCargasPaso = new();
            }

            var facturasResult = await XmlService.ListarFacturasPorChecklistAsync(ChecklistId, page: 1, limit: 500);
            if (facturasResult?.Ok == true)
            {
                _facturasXmlPaso = (facturasResult.Data ?? new())
                    .OrderByDescending(x => x.ProcesadoEn)
                    .ThenByDescending(x => x.FechaEmision)
                    .ThenByDescending(x => x.Total)
                    .ToList();

                _columnasImpuestoXml = _facturasXmlPaso
                    .SelectMany(x => x.Impuestos ?? new())
                    .Select(ObtenerClaveColumnaImpuesto)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .OrderBy(x => x)
                    .ToList();
            }
            else
            {
                _facturasXmlPaso = new();
                _columnasImpuestoXml = new();
            }

            await CargarPendientesCategoriaAsync(false);
        }
        catch
        {
            _xmlCargasPaso = new();
            _facturasXmlPaso = new();
            _columnasImpuestoXml = new();
            _pendientesCategoria = new();
        }
    }

    private async Task CargarPendientesCategoriaAsync(bool abrirSiHayPendientes)
    {
        if (_checklist == null)
        {
            _pendientesCategoria = new();
            return;
        }

        var pendientes = await XmlService.ObtenerFacturasPendientesCategoriaPorChecklistAsync(ChecklistId);
        _pendientesCategoria = (pendientes?.Ok == true ? pendientes.Data : null)?
            .OrderByDescending(x => x.ProcesadoEn)
            .ThenByDescending(x => x.FechaEmision)
            .ThenByDescending(x => x.Total)
            .Select(x => new FacturaCategoriaDraft
            {
                FacturaId = x.FacturaId,
                Uuid = x.Uuid,
                FechaEmision = x.FechaEmision,
                RfcEmisor = x.RfcEmisor,
                NombreEmisor = x.NombreEmisor,
                MetodoPago = x.MetodoPago,
                SubNeto = x.SubNeto,
                Total = x.Total,
                Impuestos = x.Impuestos ?? new(),
                CategoriaSeleccionada = x.CategoriaGastoXml
            })
            .ToList() ?? new();

        if (abrirSiHayPendientes && _pendientesCategoria.Count > 0)
        {
            _modalCategoriasVisible = true;
        }
    }

    private async Task GuardarNotas()
    {
        if (_paso == null)
        {
            return;
        }

        _guardando = true;
        var response = await ChecklistService.ActualizarPasoAsync(ChecklistId, PasoId, new UpdatePasoRequest
        {
            Notas = _notas,
            Estado = EstadoActual
        });

        if (response?.Ok == true)
        {
            _mensaje = "Notas guardadas correctamente.";
            await Cargar();
        }
        else
        {
            _error = response?.Error?.Message;
        }

        _guardando = false;
    }

    private async Task CompletarPaso() => await Cambiar("completado");
    private async Task BloquearPaso() => await Cambiar("bloqueado");
    private async Task DesbloquearPaso() => await Cambiar("en_proceso");

    private async Task Cambiar(string estado)
    {
        var response = await ChecklistService.ActualizarPasoAsync(ChecklistId, PasoId, new UpdatePasoRequest
        {
            Estado = estado,
            Notas = _notas
        });

        if (response?.Ok == true)
        {
            _mensaje = estado switch
            {
                "completado" => "Paso completado.",
                "bloqueado" => "Paso bloqueado.",
                "en_proceso" => "Paso reactivado.",
                _ => "Paso actualizado."
            };
            await Cargar();
        }
        else
        {
            _error = response?.Error?.Message;
        }
    }

    private async Task OnArchivoSeleccionado(InputFileChangeEventArgs e)
    {
        if (e.FileCount > 0)
        {
            _archivo = e.File;
            _archivoNombre = e.File.Name;
        }
        else
        {
            _archivo = null;
            _archivoNombre = null;
        }

        await Task.CompletedTask;
    }

    private async Task OnArchivoXmlSeleccionado(InputFileChangeEventArgs e, string tipoCarga)
    {
        var file = e.FileCount > 0 ? e.File : null;
        if (tipoCarga == "emitidos")
        {
            _archivoEmitidos = file;
            _archivoEmitidosNombre = file?.Name;
        }
        else
        {
            _archivoRecibidos = file;
            _archivoRecibidosNombre = file?.Name;
        }

        await Task.CompletedTask;
    }

    private Task OnArchivoEmitidosSeleccionado(InputFileChangeEventArgs e)
        => OnArchivoXmlSeleccionado(e, "emitidos");

    private Task OnArchivoRecibidosSeleccionado(InputFileChangeEventArgs e)
        => OnArchivoXmlSeleccionado(e, "recibidos");

    private async Task SubirXml(string tipoCarga)
    {
        if (_checklist == null)
        {
            return;
        }

        var archivo = tipoCarga == "emitidos" ? _archivoEmitidos : _archivoRecibidos;
        if (archivo == null)
        {
            return;
        }

        if (tipoCarga == "emitidos")
        {
            _subiendoEmitidos = true;
        }
        else
        {
            _subiendoRecibidos = true;
        }

        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(archivo.OpenReadStream(50 * 1024 * 1024));
            var mime = Path.GetExtension(archivo.Name).Equals(".rar", StringComparison.OrdinalIgnoreCase)
                ? "application/vnd.rar"
                : "application/zip";
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(mime);
            content.Add(fileContent, "archivo", archivo.Name);
            content.Add(new StringContent(_checklist.ClienteId.ToString()), "clienteId");
            content.Add(new StringContent(_checklist.PeriodoId.ToString()), "periodoId");
            content.Add(new StringContent(ChecklistId.ToString()), "checklistId");
            content.Add(new StringContent(PasoId.ToString()), "pasoId");
            content.Add(new StringContent(tipoCarga), "tipoCarga");

            var result = await XmlService.SubirCargaAsync(content);
            if (result?.Ok == true)
            {
                var carga = result.Data;
                _mensaje = carga != null && carga.ConErrores > 0
                    ? $"Se procesaron {carga.Procesados} XML de {TituloTipoCarga(tipoCarga).ToLowerInvariant()} y {carga.ConErrores} quedaron rechazados por direccion incorrecta o por error de lectura."
                    : $"Carga de {TituloTipoCarga(tipoCarga).ToLowerInvariant()} procesada correctamente.";
                if (tipoCarga == "emitidos")
                {
                    _archivoEmitidos = null;
                    _archivoEmitidosNombre = null;
                    _subiendoEmitidos = false;
                }
                else
                {
                    _archivoRecibidos = null;
                    _archivoRecibidosNombre = null;
                    _subiendoRecibidos = false;
                }

                await CargarXmlPasoAsync();
                await CargarPendientesCategoriaAsync(true);
                return;
            }

            _error = result?.Error?.Message ?? $"No se pudo procesar la carga de {tipoCarga}.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            if (tipoCarga == "emitidos")
            {
                _subiendoEmitidos = false;
            }
            else
            {
                _subiendoRecibidos = false;
            }
        }
    }

    private void SolicitarEliminarFactura(long facturaId)
    {
        _facturaPendienteEliminarId = facturaId;
    }

    private void CancelarEliminarFactura()
    {
        _facturaPendienteEliminarId = null;
    }

    private async Task EliminarFactura(long facturaId)
    {
        _eliminandoFactura = true;
        try
        {
            var result = await XmlService.EliminarFacturaAsync(facturaId);
            if (result?.Ok == true)
            {
                _mensaje = "XML eliminado del checklist actual.";
                _facturaPendienteEliminarId = null;
                await CargarXmlPasoAsync();
            }
            else
            {
                _error = result?.Error?.Message ?? "No se pudo eliminar el XML.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _eliminandoFactura = false;
        }
    }

    private Task SubirXmlEmitidos()
        => SubirXml("emitidos");

    private Task SubirXmlRecibidos()
        => SubirXml("recibidos");

    private void AbrirModalCategorias()
    {
        _modalCategoriasVisible = true;
    }

    private void CerrarModalCategorias()
    {
        _modalCategoriasVisible = false;
        _categoriaLote = null;
        foreach (var factura in _pendientesCategoria)
        {
            factura.Seleccionado = false;
        }
    }

    private void AplicarCategoriaLote()
    {
        if (string.IsNullOrWhiteSpace(_categoriaLote))
        {
            return;
        }

        foreach (var factura in _pendientesCategoria.Where(x => x.Seleccionado))
        {
            factura.CategoriaSeleccionada = _categoriaLote;
        }
    }

    private async Task GuardarCategoriasPendientes()
    {
        if (_checklist == null)
        {
            return;
        }

        var items = _pendientesCategoria
            .Where(x => !string.IsNullOrWhiteSpace(x.CategoriaSeleccionada))
            .Select(x => new ActualizarCategoriaFacturaItemDto
            {
                FacturaId = x.FacturaId,
                Categoria = x.CategoriaSeleccionada
            })
            .ToList();

        if (items.Count == 0)
        {
            _mensaje = "No hay categorias nuevas para guardar.";
            return;
        }

        _guardandoCategorias = true;
        try
        {
            var result = await XmlService.ActualizarCategoriasFacturasAsync(new ActualizarCategoriasFacturasRequest
            {
                ClienteId = _checklist.ClienteId,
                PeriodoId = _checklist.PeriodoId,
                Items = items
            });

            if (result?.Ok == true)
            {
                _mensaje = "Categorias guardadas correctamente.";
                _modalCategoriasVisible = false;
                await CargarXmlPasoAsync();
            }
            else
            {
                _error = result?.Error?.Message ?? "No se pudieron guardar las categorias.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _guardandoCategorias = false;
        }
    }

    private async Task SubirEvidencia()
    {
        if (_archivo == null)
        {
            return;
        }

        _subiendo = true;

        try
        {
            using var content = new MultipartFormDataContent();
            var stream = _archivo.OpenReadStream(25 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_archivo.ContentType);
            content.Add(fileContent, "archivo", _archivo.Name);

            var response = await Http.PostAsync($"api/v1/checklists/{ChecklistId}/pasos/{PasoId}/evidencias", content);
            if (response.IsSuccessStatusCode)
            {
                _archivo = null;
                _archivoNombre = null;
                _mensaje = "Evidencia subida correctamente.";
                await Cargar();
            }
            else
            {
                _error = "Error al subir la evidencia";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _subiendo = false;
    }

