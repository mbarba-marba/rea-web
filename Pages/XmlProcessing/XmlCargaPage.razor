@page "/xml"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "admin,auxiliar")]
@inject NavigationManager Navigation

<div class="page-container animate-fade-in">
    <div class="card" style="padding:24px;max-width:720px;">
        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Flujo actualizado</div>
        <h1 style="margin-top:6px;">La carga XML ahora vive en el paso 2 del checklist</h1>
        <p class="body-small text-muted" style="margin-top:10px;">
            Vamos a llevarte al libro de trabajo para continuar desde el expediente del cliente y periodo correctos.
        </p>
    </div>
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        Navigation.NavigateTo("/checklists", replace: true);
    }
}
