@page "/clientes"
@using Microsoft.AspNetCore.Authorization
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin")]
@inject ClienteService ClienteService
@inject NavigationManager Navigation

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:16px;">
        <div class="page-header-left">
            <h1>Clientes</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Alta y gestion de clientes del despacho</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <GlassButton Variant="secondary" OnClick="IrAAsignaciones" style="border-color:var(--glass-border);">
                <LucideIcon Name="link" Size="16" /> Asignaciones
            </GlassButton>
            <GlassButton Variant="primary" OnClick="IrANuevo">
                <LucideIcon Name="plus" Size="16" /> Nuevo Cliente
            </GlassButton>
        </div>
    </div>

    <ErrorBanner Message="@_error" OnDismiss="() => _error = null" />

    <div class="glass-card" style="margin-bottom:16px;padding:18px 20px;background:color-mix(in srgb, var(--glass-bg-primary) 82%, var(--bg-base) 18%);">
        <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px;">Buscar cliente</div>
        <div style="display:grid;grid-template-columns:minmax(280px,1fr) 220px auto;gap:12px;align-items:center;">
            <input type="text"
                   class="input-field"
                   @bind="_busqueda"
                   @bind:event="oninput"
                   placeholder="RFC, razon social o nombre comercial" />
            <select @bind="_clasificacion" class="select-field" style="height:40px;">
                <option value="">Todas las clasificaciones</option>
                <option value="activo">Activos</option>
                <option value="irregular">Irregulares</option>
            </select>
            <div style="display:flex;gap:10px;justify-content:flex-end;">
                <GlassButton Variant="secondary" OnClick="Limpiar" style="border-color:var(--glass-border);">Limpiar</GlassButton>
                <GlassButton Variant="primary" OnClick="Buscar">Aplicar filtros</GlassButton>
            </div>
        </div>
    </div>

    @if (_cargando)
    {
        <div class="glass-card" style="text-align:center;padding:56px;background:color-mix(in srgb, var(--glass-bg-primary) 82%, var(--bg-base) 18%);">
            <span style="color:var(--text-secondary);">Cargando clientes...</span>
        </div>
    }
    else if (_clientes.Count == 0)
    {
        <div class="glass-card empty-state" style="padding:56px 32px;background:color-mix(in srgb, var(--glass-bg-primary) 82%, var(--bg-base) 18%);">
            <LucideIcon Name="users" Size="44" />
            <p class="empty-state-heading">No hay clientes para mostrar</p>
            <p class="empty-state-body">Ajusta los filtros o registra un cliente nuevo para comenzar.</p>
        </div>
    }
    else
    {
        <div class="glass-card" style="padding:0;overflow:hidden;background:color-mix(in srgb, var(--glass-bg-primary) 84%, var(--bg-base) 16%);">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid var(--border-subtle);background:color-mix(in srgb, var(--glass-bg-primary) 72%, var(--bg-base) 28%);">
                <span style="font-size:12px;color:var(--text-secondary);text-transform:uppercase;">Listado</span>
                <span style="font-size:13px;color:var(--text-secondary);">@_clientes.Count clientes</span>
            </div>
            <div style="overflow-x:auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>RFC</th>
                            <th>Razon Social</th>
                            <th>Nombre Comercial</th>
                            <th>Clasificacion</th>
                            <th>E-Firma</th>
                            <th style="width:96px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _clientes)
                        {
                            <tr style="cursor:pointer" @onclick="() => VerCliente(c.ClienteId)">
                                <td class="mono">@c.Rfc</td>
                                <td style="font-weight:500;">@c.RazonSocial</td>
                                <td>@(string.IsNullOrWhiteSpace(c.NombreComercial) ? "-" : c.NombreComercial)</td>
                                <td><BadgeCliente Clasificacion="@c.Clasificacion" /></td>
                                <td><BadgeEstado Estado="@(c.EstatusEfirma?.ToLower() ?? "pendiente")" /></td>
                                <td style="position:relative;">
                                    <button class="btn btn-ghost btn-sm btn-icon"
                                            title="Acciones"
                                            @onclick:stopPropagation
                                            @onclick="() => ToggleAcciones(c.ClienteId)">
                                        <LucideIcon Name="ellipsis" Size="14" />
                                    </button>
                                    @if (_menuAccionesClienteId == c.ClienteId)
                                    {
                                        <div @onclick:stopPropagation
                                             style="position:absolute;right:12px;top:38px;z-index:30;background:var(--glass-bg-primary);border:1px solid var(--glass-border);border-radius:8px;box-shadow:var(--shadow-mid);min-width:120px;padding:6px;">
                                            <button class="btn btn-ghost btn-sm"
                                                    style="width:100%;justify-content:flex-start;color:var(--text-primary);"
                                                    @onclick="() => EditarDesdeMenu(c.ClienteId)">
                                                <LucideIcon Name="pencil" Size="14" /> Editar
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<BreadcrumbItem> _breadcrumb = new()
    {
        new() { Text = "Inicio", Url = "/" },
        new() { Text = "Clientes", Url = "/clientes" }
    };

    private List<ClienteDto> _clientes = new();
    private string _busqueda = "";
    private string _clasificacion = "";
    private bool _cargando = true;
    private string? _error;
    private long? _menuAccionesClienteId;

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    private async Task Buscar()
    {
        _cargando = true;
        _error = null;
        try
        {
            var result = await ClienteService.ListarAsync(_clasificacion, _busqueda);
            if (result?.Ok == true)
                _clientes = result.Data ?? new();
            else
                _error = result?.Error?.Message ?? "Error al cargar clientes";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _cargando = false;
    }

    private async Task Limpiar()
    {
        _busqueda = "";
        _clasificacion = "";
        await Buscar();
    }

    private void Editar(long id) => Navigation.NavigateTo($"/clientes/{id}/editar");
    private void VerCliente(long id) => Navigation.NavigateTo($"/clientes/{id}");
    private void IrANuevo() => Navigation.NavigateTo("/clientes/nuevo");
    private void IrAAsignaciones() => Navigation.NavigateTo("/asignaciones");
    private void ToggleAcciones(long id) => _menuAccionesClienteId = _menuAccionesClienteId == id ? null : id;
    private void EditarDesdeMenu(long id)
    {
        _menuAccionesClienteId = null;
        Editar(id);
    }
}
