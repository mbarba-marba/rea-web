@page "/clientes/nuevo"
@page "/clientes/{Id:long}/editar"
@using Microsoft.AspNetCore.Authorization
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin,auxiliar")]
@inject ClienteService ClienteService
@inject NavigationManager Navigation

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:20px;align-items:flex-start;gap:16px;">
        <div class="page-header-left">
            <h1>@(EsEdicion ? "Editar Cliente" : "Nuevo Cliente")</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">
                @(EsEdicion ? "Actualiza la ficha operativa y fiscal del cliente." : "Registra una nueva cuenta con la informacion fiscal y de contacto.")
            </p>
        </div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <GlassButton Variant="secondary" OnClick="Cancelar">
                <LucideIcon Name="arrow-left" Size="16" /> Volver
            </GlassButton>
            <GlassButton Variant="primary" OnClick="Guardar" Disabled="@(_guardando || _cargando)">
                <LucideIcon Name="save" Size="16" />
                @(_guardando ? "Guardando..." : (EsEdicion ? "Actualizar Cliente" : "Crear Cliente"))
            </GlassButton>
        </div>
    </div>

    @if (_error != null)
    {
        <div style="margin-bottom:16px;">
            <ErrorBanner Message="@_error" OnDismiss="() => _error = null" />
        </div>
    }

    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else
    {
        <div style="display:grid;grid-template-columns:minmax(0,1.55fr) minmax(280px,0.75fr);gap:18px;align-items:start;">
            <div style="display:grid;gap:16px;">
                <div class="card" style="padding:0;overflow:hidden;">
                    <div class="surface-panel-header" style="padding:16px 20px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
                            <div>
                                <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Identidad fiscal</div>
                                <h3 style="margin-top:4px;">Datos principales del cliente</h3>
                            </div>
                            @if (EsEdicion)
                            {
                                <span class="badge badge-accent" style="padding:6px 10px;">Edicion activa</span>
                            }
                        </div>
                    </div>

                    <div style="padding:20px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px 18px;">
                        <div>
                            <label class="input-label">RFC *</label>
                            <input @bind="_form.Rfc" class="input-field" disabled="@EsEdicion" placeholder="ABC010203XYZ" />
                            <div class="body-small text-muted" style="margin-top:6px;">@(EsEdicion ? "El RFC se mantiene fijo una vez creado el cliente." : "Usa el RFC tal como aparece en la constancia fiscal.")</div>
                        </div>

                        <div>
                            <label class="input-label">Clasificacion</label>
                            <select @bind="_form.Clasificacion" class="select-field">
                                <option value="activo">Activo</option>
                                <option value="irregular">Irregular</option>
                            </select>
                        </div>

                        <div style="grid-column:1/-1;">
                            <label class="input-label">Razon Social *</label>
                            <input @bind="_form.RazonSocial" class="input-field" placeholder="Nombre legal o razon social" />
                        </div>

                        <div>
                            <label class="input-label">Nombre Comercial</label>
                            <input @bind="_form.NombreComercial" class="input-field" placeholder="Marca o nombre visible" />
                        </div>

                        <div>
                            <label class="input-label">Regimen Fiscal</label>
                            <input @bind="_form.RegimenFiscal" class="input-field" placeholder="Ej. Persona Moral, Sueldos y Salarios..." />
                        </div>

                        <div>
                            <label class="input-label">Actividad</label>
                            <input @bind="_form.Actividad" class="input-field" placeholder="Actividad economica principal" />
                        </div>

                        <div>
                            <label class="input-label">% Actividad</label>
                            <input @bind="_form.PorcentajeAct" class="input-field" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>
                </div>

                <div class="card" style="padding:0;overflow:hidden;">
                    <div class="surface-panel-header" style="padding:16px 20px;">
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Contacto y seguimiento</div>
                        <h3 style="margin-top:4px;">Canales de contacto del cliente</h3>
                    </div>

                    <div style="padding:20px;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px 18px;">
                        <div>
                            <label class="input-label">Email</label>
                            <input @bind="_form.Email" class="input-field" type="email" placeholder="cliente@empresa.com" />
                        </div>

                        <div>
                            <label class="input-label">Telefono</label>
                            <input @bind="_form.Telefono" class="input-field" placeholder="664-000-0000" />
                        </div>

                        <div style="grid-column:1/-1;">
                            <label class="input-label">Direccion</label>
                            <input @bind="_form.Direccion" class="input-field" placeholder="Calle, numero, colonia y ciudad" />
                        </div>
                    </div>
                </div>
            </div>

            <div style="display:grid;gap:16px;">
                <div class="card" style="padding:20px;">
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Resumen</div>
                    <h3 style="margin-top:4px;margin-bottom:14px;">Vista rapida</h3>

                    <div style="display:grid;gap:14px;">
                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Estado del registro</div>
                            @if (EsEdicion)
                            {
                                <span class="badge badge-accent">Actualizando ficha existente</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Pendiente de crear</span>
                            }
                        </div>

                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Clasificacion seleccionada</div>
                            <span class="badge @(ClasificacionBadgeClass)">@ClasificacionBadgeText</span>
                        </div>

                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Cliente</div>
                            <div style="font-size:15px;font-weight:600;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_form.RazonSocial) ? "Sin nombre capturado" : _form.RazonSocial)</div>
                            <div class="mono" style="font-size:12px;color:var(--text-secondary);margin-top:4px;">@(string.IsNullOrWhiteSpace(_form.Rfc) ? "RFC pendiente" : _form.Rfc)</div>
                        </div>
                    </div>
                </div>

                <div class="card" style="padding:20px;">
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Checklist de captura</div>
                    <h3 style="margin-top:4px;margin-bottom:14px;">Recomendaciones</h3>

                    <div style="display:grid;gap:12px;">
                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">RFC y razon social</div>
                            <div style="color:var(--text-primary);">Asegura que coincidan con la documentacion fiscal.</div>
                        </div>

                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Contacto</div>
                            <div style="color:var(--text-primary);">Deja un correo valido para seguimiento de pendientes y alertas.</div>
                        </div>

                        <div>
                            <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Clasificacion</div>
                            <div style="color:var(--text-primary);">La clasificacion impacta reportes y vistas operativas del despacho.</div>
                        </div>
                    </div>
                </div>

                <div class="card" style="padding:20px;">
                    <div style="display:flex;flex-direction:column;gap:10px;">
                        <GlassButton Variant="primary" OnClick="Guardar" Disabled="@(_guardando || _cargando)">
                            <LucideIcon Name="save" Size="16" />
                            @(_guardando ? "Guardando..." : (EsEdicion ? "Guardar cambios" : "Crear cliente"))
                        </GlassButton>
                        <GlassButton Variant="secondary" OnClick="Cancelar">
                            <LucideIcon Name="x" Size="16" /> Cancelar
                        </GlassButton>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private CreateClienteRequest _form = new();
    private bool _guardando;
    private bool _cargando = true;
    private string? _error;
    private readonly List<BreadcrumbItem> _breadcrumb = new();

    private bool EsEdicion => Id > 0;

    private string ClasificacionBadgeClass => (_form.Clasificacion ?? "activo").ToLower() switch
    {
        "irregular" => "badge badge-warning",
        _ => "badge badge-success"
    };

    private string ClasificacionBadgeText => (_form.Clasificacion ?? "activo").ToLower() switch
    {
        "irregular" => "Irregular",
        _ => "Activo"
    };

    protected override async Task OnInitializedAsync()
    {
        ConstruirBreadcrumb();

        if (EsEdicion)
        {
            await CargarCliente();
        }

        _cargando = false;
    }

    private void ConstruirBreadcrumb()
    {
        _breadcrumb.Clear();
        _breadcrumb.Add(new BreadcrumbItem { Text = "Inicio", Url = "/" });
        _breadcrumb.Add(new BreadcrumbItem { Text = "Clientes", Url = "/clientes" });
        _breadcrumb.Add(new BreadcrumbItem
        {
            Text = EsEdicion ? "Editar cliente" : "Nuevo cliente",
            Url = EsEdicion ? $"/clientes/{Id}/editar" : "/clientes/nuevo"
        });
    }

    private async Task CargarCliente()
    {
        try
        {
            var result = await ClienteService.ObtenerAsync(Id);
            if (result?.Ok == true && result.Data != null)
            {
                var c = result.Data;
                _form = new CreateClienteRequest
                {
                    Rfc = c.Rfc,
                    RazonSocial = c.RazonSocial,
                    NombreComercial = c.NombreComercial,
                    Clasificacion = c.Clasificacion,
                    Actividad = c.Actividad,
                    PorcentajeAct = c.PorcentajeAct,
                    RegimenFiscal = c.RegimenFiscal,
                    Email = c.Email,
                    Telefono = c.Telefono,
                    Direccion = c.Direccion
                };
            }
            else
            {
                _error = result?.Error?.Message ?? "No se pudo cargar el cliente.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Guardar()
    {
        _error = null;
        _guardando = true;

        try
        {
            if (EsEdicion)
            {
                var req = new UpdateClienteRequest
                {
                    RazonSocial = _form.RazonSocial,
                    NombreComercial = _form.NombreComercial,
                    Clasificacion = _form.Clasificacion,
                    Actividad = _form.Actividad,
                    PorcentajeAct = _form.PorcentajeAct,
                    RegimenFiscal = _form.RegimenFiscal,
                    Email = _form.Email,
                    Telefono = _form.Telefono,
                    Direccion = _form.Direccion
                };

                var result = await ClienteService.ActualizarAsync(Id, req);
                if (result?.Ok == true)
                {
                    Navigation.NavigateTo("/clientes");
                    return;
                }

                _error = result?.Error?.Message;
            }
            else
            {
                var result = await ClienteService.CrearAsync(_form);
                if (result?.Ok == true)
                {
                    Navigation.NavigateTo("/clientes");
                    return;
                }

                _error = result?.Error?.Message;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _guardando = false;
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/clientes");
}
