@page "/clientes/{Id:long}"
@using Microsoft.AspNetCore.Authorization
@using REA.Web.Components.Shared
@using REA.Web.Models
@using REA.Web.Services
@attribute [Authorize(Roles = "admin,auxiliar")]
@inject ClienteService ClienteService
@inject NavigationManager Navigation

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:16px;">
        <div class="page-header-left">
            <h1>@(_cliente?.RazonSocial ?? "Cliente")</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Detalle operativo del cliente</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <GlassButton Variant="secondary" OnClick="Volver">
                <LucideIcon Name="arrow-left" Size="16" /> Volver
            </GlassButton>
            <GlassButton Variant="primary" OnClick="EditarActual">
                <LucideIcon Name="pencil" Size="16" /> Editar
            </GlassButton>
        </div>
    </div>

    <ErrorBanner Message="@_error" OnDismiss="() => _error = null" />

    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else if (_cliente != null)
    {
        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:16px;">
            <div class="glass-card" style="padding:14px 16px;background:rgba(255,255,255,0.86);">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">RFC</div>
                <div class="mono" style="font-size:13px;color:var(--text-primary);">@_cliente.Rfc</div>
            </div>
            <div class="glass-card" style="padding:14px 16px;background:rgba(255,255,255,0.86);">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Clasificacion</div>
                <div><BadgeCliente Clasificacion="@_cliente.Clasificacion" /></div>
            </div>
            <div class="glass-card" style="padding:14px 16px;background:rgba(255,255,255,0.86);">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">E-Firma</div>
                <div><BadgeEstado Estado="@(_cliente.EstatusEfirma?.ToLower() ?? "pendiente")" /></div>
            </div>
            <div class="glass-card" style="padding:14px 16px;background:rgba(255,255,255,0.86);">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Auxiliares</div>
                <div style="font-size:20px;font-weight:700;color:var(--text-primary);">@_cliente.Asignaciones.Count</div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1.3fr 1fr;gap:16px;align-items:stretch;">
            <div class="glass-card" style="padding:20px;background:rgba(255,255,255,0.82);height:100%;">
                <h3 style="margin-bottom:14px;">Informacion General</h3>
                <div style="display:grid;gap:12px;">
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">RFC</div><div class="mono" style="font-size:16px;font-weight:600;color:var(--text-primary);">@_cliente.Rfc</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Razon Social</div><div style="font-size:18px;font-weight:600;color:var(--text-primary);">@_cliente.RazonSocial</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Nombre Comercial</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.NombreComercial) ? "-" : _cliente.NombreComercial)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Clasificacion</div><div style="margin-top:2px;"><BadgeCliente Clasificacion="@_cliente.Clasificacion" /></div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Regimen Fiscal</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.RegimenFiscal) ? "-" : _cliente.RegimenFiscal)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Actividad</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.Actividad) ? "-" : _cliente.Actividad)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">% Actividad</div><div style="font-size:16px;font-weight:600;color:var(--text-primary);">@(_cliente.PorcentajeAct?.ToString("0.##") ?? "-")%</div></div>
                </div>
            </div>

            <div class="glass-card" style="padding:20px;background:rgba(255,255,255,0.82);height:100%;">
                <h3 style="margin-bottom:12px;">Contacto y Estado</h3>
                <div style="display:grid;gap:12px;">
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Email</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.Email) ? "-" : _cliente.Email)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Telefono</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.Telefono) ? "-" : _cliente.Telefono)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Direccion</div><div style="font-size:16px;font-weight:500;color:var(--text-primary);">@(string.IsNullOrWhiteSpace(_cliente.Direccion) ? "-" : _cliente.Direccion)</div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Estatus E-Firma</div><div style="margin-top:2px;"><BadgeEstado Estado="@(_cliente.EstatusEfirma?.ToLower() ?? "pendiente")" /></div></div>
                    <div><div style="font-size:11px;color:var(--text-secondary);text-transform:uppercase;">Activo</div><div style="margin-top:2px;">
                        @if (_cliente.Activo)
                        {
                            <span class="badge badge-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge badge-muted">Inactivo</span>
                        }
                    </div></div>
                </div>
            </div>

            <div class="glass-card" style="padding:20px;background:rgba(255,255,255,0.82);grid-column:1/-1;">
                <h3 style="margin-bottom:12px;">Vigencias</h3>
                <div style="display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;">
                    <div style="padding:10px 12px;border:1px solid var(--glass-border);border-radius:10px;background:color-mix(in srgb, var(--glass-bg-primary) 88%, var(--bg-base) 12%);">
                        <div style="font-size:11px;color:var(--text-secondary);">E-Firma Inicio</div>
                        <div style="font-weight:600;color:var(--text-primary);">@FmtDate(_cliente.EFirmaVigenciaInicio)</div>
                    </div>
                    <div style="padding:10px 12px;border:1px solid var(--glass-border);border-radius:10px;background:color-mix(in srgb, var(--glass-bg-primary) 88%, var(--bg-base) 12%);">
                        <div style="font-size:11px;color:var(--text-secondary);">E-Firma Fin</div>
                        <div style="font-weight:600;color:var(--text-primary);">@FmtDate(_cliente.EFirmaVigenciaFin)</div>
                    </div>
                    <div style="padding:10px 12px;border:1px solid var(--glass-border);border-radius:10px;background:color-mix(in srgb, var(--glass-bg-primary) 88%, var(--bg-base) 12%);">
                        <div style="font-size:11px;color:var(--text-secondary);">CIEE Inicio</div>
                        <div style="font-weight:600;color:var(--text-primary);">@FmtDate(_cliente.CieeVigenciaInicio)</div>
                    </div>
                    <div style="padding:10px 12px;border:1px solid var(--glass-border);border-radius:10px;background:color-mix(in srgb, var(--glass-bg-primary) 88%, var(--bg-base) 12%);">
                        <div style="font-size:11px;color:var(--text-secondary);">CIEE Fin</div>
                        <div style="font-weight:600;color:var(--text-primary);">@FmtDate(_cliente.CieeVigenciaFin)</div>
                    </div>
                    <div style="padding:10px 12px;border:1px solid var(--glass-border);border-radius:10px;background:color-mix(in srgb, var(--glass-bg-primary) 88%, var(--bg-base) 12%);">
                        <div style="font-size:11px;color:var(--text-secondary);">Alta</div>
                        <div style="font-weight:600;color:var(--text-primary);">@_cliente.CreatedAt.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>
            </div>

            <div class="glass-card" style="padding:20px;background:rgba(255,255,255,0.82);grid-column:1/-1;">
                <h3 style="margin-bottom:12px;">Auxiliares Asignados</h3>
                @if (_cliente.Asignaciones.Count == 0)
                {
                    <p style="color:var(--text-secondary);">Sin auxiliares asignados</p>
                }
                else
                {
                    <div style="display:flex;flex-wrap:wrap;gap:8px;">
                        @foreach (var a in _cliente.Asignaciones)
                        {
                            <span class="badge badge-accent" style="padding:6px 10px;">@a.AuxiliarNombre</span>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public long Id { get; set; }

    private ClienteDto? _cliente;
    private bool _cargando = true;
    private string? _error;
    private List<BreadcrumbItem> _breadcrumb = new();

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        try
        {
            var result = await ClienteService.ObtenerAsync(Id);
            if (result?.Ok == true && result.Data != null)
            {
                _cliente = result.Data;
                _breadcrumb = new()
                {
                    new() { Text = "Inicio", Url = "/" },
                    new() { Text = "Clientes", Url = "/clientes" },
                    new() { Text = _cliente.Rfc, Url = $"/clientes/{Id}" }
                };
            }
            else
            {
                _error = result?.Error?.Message ?? "No se pudo cargar el cliente";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _cargando = false;
    }

    private static string FmtDate(DateOnly? date) => date?.ToString("dd/MM/yyyy") ?? "-";
    private void Volver() => Navigation.NavigateTo("/clientes");
    private void EditarActual() => Navigation.NavigateTo($"/clientes/{Id}/editar");
}
