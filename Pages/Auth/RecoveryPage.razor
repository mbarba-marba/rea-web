@page "/auth/recovery"
@layout AuthLayout
@using REA.Web.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page animate-fade-in">
    <div class="login-card glass-elevation-2">
        <div class="login-logo">
            <span style="font-size:28px;font-weight:700;color:var(--accent);font-family:var(--font-mono);">REA</span>
        </div>
        <h1 class="login-title">Recuperación MFA</h1>
        <p class="login-subtitle">Usa un código de respaldo para acceder</p>

        <EditForm Model="_model" OnValidSubmit="Recuperar" FormName="recovery">
            <div style="display:flex;flex-direction:column;gap:12px;">
                <div>
                    <label class="input-label">Email</label>
                    <InputText class="input-field" @bind-Value="_model.Email" placeholder="usuario@despacho.com" />
                </div>
                <div>
                    <label class="input-label">Código de respaldo</label>
                    <InputText class="input-field" @bind-Value="_model.Codigo" placeholder="XXXXXXXX" maxlength="8" />
                </div>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="error-banner">@_error</div>
                }
                @if (_success)
                {
                    <div style="color:var(--success);">
                        Acceso exitoso. <a href="/" style="color:var(--accent);">Ir al dashboard</a>
                    </div>
                }
                else
                {
                    <button type="submit" class="btn btn-primary" style="width:100%;" disabled="@_cargando">
                        @(_cargando ? "Verificando..." : "Recuperar Acceso")
                    </button>
                }
            </div>
        </EditForm>
    </div>
</div>

@code {
    private RecoveryModel _model = new();
    private string? _error;
    private bool _cargando;
    private bool _success;

    private class RecoveryModel
    {
        [System.ComponentModel.DataAnnotations.Required] public string Email { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string Codigo { get; set; } = "";
    }

    private async Task Recuperar()
    {
        _error = null; _cargando = true;
        try
        {
            // Uses AuthService.LoginAsync with the recovery flow
            var result = await AuthService.LoginAsync(_model.Email, _model.Codigo);
            if (result?.Ok == true) _success = true;
            else _error = result?.Error?.Message ?? "Código inválido o ya usado";
        }
        catch (Exception ex) { _error = ex.Message; }
        _cargando = false;
    }
}
