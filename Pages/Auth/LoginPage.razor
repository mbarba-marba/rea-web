@page "/login"
@layout AuthLayout
@using System.ComponentModel.DataAnnotations
@using REA.Web.Models
@using REA.Web.Services
@using REA.Web.Providers
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="login-page animate-fade-in">
    <div class="login-card glass-elevation-2">
        <div class="login-logo">
            <img src="/img/logo-rea.png" alt="REA" style="width:88px;height:88px;object-fit:contain;filter:drop-shadow(0 10px 18px rgba(7,98,128,0.14));" />
        </div>

        @if (_mostrarMfa)
        {
            <h1 class="login-title">VerificaciÃ³n MFA</h1>
            <p class="login-subtitle">Ingrese el cÃ³digo de su aplicaciÃ³n autenticadora</p>

            <EditForm Model="_mfaModel" OnValidSubmit="HandleMfaVerify" FormName="mfa">
                <div style="display:flex;flex-direction:column;gap:var(--space-md);">
                    <div>
                        <label class="input-label" for="codigo">CÃ³digo TOTP (6 dÃ­gitos)</label>
                        <InputText id="codigo"
                                   class="input-field"
                                   @bind-Value="_mfaModel.CodigoTotp"
                                   placeholder="123456"
                                   maxlength="6" />
                        <ValidationMessage For="() => _mfaModel.CodigoTotp" />
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="error-banner">
                            <span class="error-banner-icon"><LucideIcon Name="circle-alert" /></span>
                            @_error
                        </div>
                    }

                    <button type="submit" class="btn btn-primary" style="width:100%;" disabled="@_loading">
                        @if (_loading)
                        {
                            <LucideIcon Name="loader-circle" />
                            <span>Verificando...</span>
                        }
                        else
                        {
                            <span>Verificar</span>
                        }
                    </button>
                </div>
            </EditForm>
        }
        else
        {
            <h1 class="login-title">Iniciar sesiÃ³n</h1>
            <p class="login-subtitle">GestiÃ³n Contable â€” Conafis</p>

            <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
                <div style="display:flex;flex-direction:column;gap:var(--space-md);">
                    <div>
                        <label class="input-label" for="email">Email</label>
                        <InputText id="email"
                                   class="input-field"
                                   @bind-Value="_model.Email"
                                   placeholder="usuario@despacho.com" />
                        <ValidationMessage For="() => _model.Email" />
                    </div>

                    <div>
                        <label class="input-label" for="password">ContraseÃ±a</label>
                        <InputText id="password"
                                   type="password"
                                   class="input-field"
                                   @bind-Value="_model.Password"
                                   placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" />
                        <ValidationMessage For="() => _model.Password" />
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="error-banner">
                            <span class="error-banner-icon"><LucideIcon Name="circle-alert" /></span>
                            @_error
                        </div>
                    }

                    <button type="submit" class="btn btn-primary" style="width:100%;" disabled="@_loading">
                        @if (_loading)
                        {
                            <LucideIcon Name="loader-circle" />
                            <span>Ingresando...</span>
                        }
                        else
                        {
                            <span>Ingresar</span>
                        }
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    private LoginModel _model = new();
    private MfaModel _mfaModel = new();
    private string? _error;
    private bool _loading;
    private bool _mostrarMfa;
    private string? _mfaTempToken;

    private class LoginModel
    {
        [Required(ErrorMessage = "El email es requerido")]
        [EmailAddress(ErrorMessage = "Email invÃ¡lido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseÃ±a es requerida")]
        public string Password { get; set; } = string.Empty;
    }

    private class MfaModel
    {
        [Required(ErrorMessage = "El cÃ³digo es requerido")]
        [StringLength(6, MinimumLength = 6, ErrorMessage = "Debe tener 6 dÃ­gitos")]
        public string CodigoTotp { get; set; } = string.Empty;
    }

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;

        try
        {
            var result = await AuthService.LoginAsync(_model.Email, _model.Password);

            if (result?.Ok == true && result.Data != null)
            {
                if (result.Data.RequiereMfa)
                {
                    _mfaTempToken = result.Data.MfaTokenTemp;
                    _mostrarMfa = true;
                }
                else
                {
                    var authState = (ReaAuthStateProvider)AuthStateProvider;
                    await authState.MarkUserAsAuthenticated(result.Data.AccessToken);
                    Navigation.NavigateTo("/");
                }
            }
            else
            {
                _error = result?.Error?.Message ?? "Credenciales invÃ¡lidas.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error de conexiÃ³n: {ex.Message}";
        }

        _loading = false;
    }

    private async Task HandleMfaVerify()
    {
        _error = null;
        _loading = true;

        try
        {
            var result = await AuthService.VerifyMfaAsync(_mfaTempToken!, _mfaModel.CodigoTotp);

            if (result?.Ok == true && result.Data != null)
            {
                var authState = (ReaAuthStateProvider)AuthStateProvider;
                await authState.MarkUserAsAuthenticated(result.Data.AccessToken);
                Navigation.NavigateTo("/");
            }
            else
            {
                _error = result?.Error?.Message ?? "CÃ³digo invÃ¡lido.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }

        _loading = false;
    }
}

