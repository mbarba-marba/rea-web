@page "/asignaciones"
@using Microsoft.AspNetCore.Authorization
@using REA.Web.Components.Shared
@attribute [Authorize(Roles = "admin")]
@inject HttpClient Http

<div class="page-container animate-fade-in">
    <div class="page-header" style="margin-bottom:20px;align-items:flex-start;gap:16px;">
        <div class="page-header-left">
            <h1>Asignaciones</h1>
            <Breadcrumb Items="@_breadcrumb" />
            <p class="body-small text-muted" style="margin-top:6px;">Relaciona clientes con auxiliares contables y revisa la carga operativa del despacho.</p>
        </div>

        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;justify-content:flex-end;">
            <GlassButton Variant="secondary" OnClick="LimpiarFiltros">
                <LucideIcon Name="rotate-ccw" Size="16" /> Limpiar filtros
            </GlassButton>
        </div>
    </div>

    @if (_mensaje != null)
    {
        <div class="card" style="margin-bottom:16px;padding:14px 16px;border-color:@(_mensajeError ? "rgba(239,68,68,0.24)" : "rgba(16,185,129,0.24)");background:@(_mensajeError ? "rgba(239,68,68,0.08)" : "rgba(16,185,129,0.10)");">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                <div style="display:flex;align-items:center;gap:10px;color:@(_mensajeError ? "var(--danger)" : "var(--success)")">
                    <LucideIcon Name="@(_mensajeError ? "alert-circle" : "badge-check")" Size="18" />
                    <span style="font-weight:600;">@_mensaje</span>
                </div>
                <button @onclick="() => _mensaje = null" class="btn btn-secondary btn-icon" title="Cerrar">
                    <LucideIcon Name="x" Size="14" />
                </button>
            </div>
        </div>
    }

    @if (_cargando)
    {
        <SkeletonLoader />
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-bottom:16px;">
            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Clientes</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_clientes.Count</div>
                <div class="body-small text-muted" style="margin-top:4px;">Base disponible para asignacion operativa.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Auxiliares activos</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_auxiliares.Count</div>
                <div class="body-small text-muted" style="margin-top:4px;">Usuarios elegibles para recibir clientes.</div>
            </div>

            <div class="card" style="padding:16px 18px;">
                <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:6px;">Clientes filtrados</div>
                <div style="font-size:28px;font-weight:700;color:var(--text-primary);">@_clientesFiltrados.Count</div>
                <div class="body-small text-muted" style="margin-top:4px;">Resultados segun busqueda y auxiliar seleccionado.</div>
            </div>
        </div>

        <div class="card" style="padding:0;overflow:hidden;margin-bottom:16px;">
            <div class="surface-panel-header" style="padding:16px 20px;">
                <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Exploracion</div>
                <h3 style="margin-top:4px;">Filtra y localiza asignaciones</h3>
            </div>

            <div style="padding:18px 20px;display:grid;grid-template-columns:minmax(280px,1fr) 260px auto;gap:12px;align-items:end;">
                <div>
                    <label class="input-label">Buscar cliente</label>
                    <input class="input-field"
                           placeholder="RFC o razon social"
                           @bind="_busqueda" @bind:event="oninput" />
                </div>

                <div>
                    <label class="input-label">Auxiliar</label>
                    <select class="select-field" @onchange="FiltrarAuxiliar">
                        <option value="">Todos los auxiliares</option>
                        @foreach (var a in _auxiliares)
                        {
                            <option value="@a.UsuarioId">@a.NombreCompleto</option>
                        }
                    </select>
                </div>

                <div style="display:flex;justify-content:flex-end;">
                    <div class="badge badge-muted" style="padding:8px 10px;height:40px;display:inline-flex;">
                        @_clientesFiltrados.Count resultados
                    </div>
                </div>
            </div>
        </div>

        @if (_clientesFiltrados.Count == 0)
        {
            <div class="card empty-state" style="padding:56px 32px;">
                <LucideIcon Name="users-round" Size="36" />
                <div class="empty-state-heading">No hay clientes que coincidan con los filtros actuales</div>
                <div class="empty-state-body">Ajusta la busqueda o cambia el auxiliar para volver a ver resultados.</div>
            </div>
        }
        else
        {
            <div class="card" style="padding:0;overflow:hidden;">
                <div class="surface-panel-header" style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Listado</div>
                        <h3 style="margin-top:4px;">Clientes y auxiliares asignados</h3>
                    </div>
                    <div class="body-small text-muted">@TotalAsignaciones activas en los resultados</div>
                </div>

                <div style="overflow-x:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>RFC</th>
                                <th>Auxiliares asignados</th>
                                <th style="text-align:right;width:92px;">Accion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _clientesFiltrados)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight:600;color:var(--text-primary);">@c.RazonSocial</div>
                                        <div class="body-small text-muted" style="margin-top:2px;">@c.Asignaciones.Count auxiliar(es) vinculados</div>
                                    </td>
                                    <td class="mono" style="font-size:12px;">@c.Rfc</td>
                                    <td>
                                        <div style="display:flex;flex-wrap:wrap;gap:6px;">
                                            @if (c.Asignaciones.Count == 0)
                                            {
                                                <span class="badge badge-muted">Sin asignar</span>
                                            }
                                            else
                                            {
                                                @foreach (var a in c.Asignaciones)
                                                {
                                                    <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;border:1px solid rgba(7,98,128,0.18);background:rgba(7,98,128,0.10);color:var(--accent);font-size:12px;font-weight:600;">
                                                        @a.AuxiliarNombre
                                                        <button @onclick="() => Remover(c, a)"
                                                                style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0;line-height:1;display:inline-flex;"
                                                                title="Remover asignacion">
                                                            <LucideIcon Name="x" Size="12" />
                                                        </button>
                                                    </span>
                                                }
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div style="display:flex;justify-content:flex-end;">
                                            <button class="btn btn-secondary btn-icon" title="Asignar auxiliar" @onclick="() => AbrirModal(c)">
                                                <LucideIcon Name="plus" Size="15" />
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@if (_modalAsignar && _clienteSeleccionado != null)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal-container" @onclick:stopPropagation="true" style="max-width:520px;">
            <div class="modal-header">
                <div>
                    <div style="font-size:12px;text-transform:uppercase;color:var(--text-secondary);letter-spacing:0.4px;">Nueva asignacion</div>
                    <h3 style="margin-top:4px;">Asignar auxiliar</h3>
                </div>
                <button class="btn btn-secondary btn-icon" @onclick="CerrarModal"><LucideIcon Name="x" Size="16" /></button>
            </div>

            <div style="display:grid;gap:16px;">
                <div class="card" style="padding:16px;">
                    <div style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);margin-bottom:4px;">Cliente seleccionado</div>
                    <div style="font-size:16px;font-weight:600;color:var(--text-primary);">@_clienteSeleccionado.RazonSocial</div>
                    <div class="mono" style="font-size:12px;color:var(--text-secondary);margin-top:4px;">@_clienteSeleccionado.Rfc</div>
                </div>

                <div>
                    <label class="input-label">Auxiliar disponible</label>
                    <select class="select-field" @bind="_auxiliarSeleccionadoId">
                        <option value="0">Selecciona un auxiliar</option>
                        @foreach (var a in _auxiliaresDisponibles)
                        {
                            <option value="@a.UsuarioId">@a.NombreCompleto</option>
                        }
                    </select>
                    <div class="body-small text-muted" style="margin-top:6px;">Solo se muestran auxiliares que aun no estan vinculados a este cliente.</div>
                </div>

                @if (_errorModal != null)
                {
                    <div class="body-small" style="color:var(--danger);">@_errorModal</div>
                }
            </div>

            <div class="modal-footer">
                <GlassButton Variant="secondary" OnClick="CerrarModal">Cancelar</GlassButton>
                <GlassButton Variant="primary" OnClick="Asignar" Disabled="@(_procesando || _auxiliarSeleccionadoId == 0)">
                    @(_procesando ? "Asignando..." : "Asignar auxiliar")
                </GlassButton>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<BreadcrumbItem> _breadcrumb = new()
    {
        new() { Text = "Inicio", Url = "/" },
        new() { Text = "Asignaciones", Url = "/asignaciones" }
    };

    private List<ClienteItem> _clientes = new();
    private List<AuxiliarItem> _auxiliares = new();
    private bool _cargando = true;
    private string? _mensaje;
    private bool _mensajeError;
    private string _busqueda = "";
    private long _filtroAuxiliar;

    private bool _modalAsignar;
    private ClienteItem? _clienteSeleccionado;
    private long _auxiliarSeleccionadoId;
    private string? _errorModal;
    private bool _procesando;

    private List<ClienteItem> _clientesFiltrados =>
        _clientes.Where(c =>
            (string.IsNullOrWhiteSpace(_busqueda) ||
             c.RazonSocial.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) ||
             c.Rfc.Contains(_busqueda, StringComparison.OrdinalIgnoreCase)) &&
            (_filtroAuxiliar == 0 ||
             c.Asignaciones.Any(a => a.AuxiliarId == _filtroAuxiliar))
        ).ToList();

    private int TotalAsignaciones => _clientesFiltrados.Sum(c => c.Asignaciones.Count);

    private List<AuxiliarItem> _auxiliaresDisponibles =>
        _clienteSeleccionado == null
            ? _auxiliares
            : _auxiliares.Where(a => _clienteSeleccionado.Asignaciones.All(x => x.AuxiliarId != a.UsuarioId)).ToList();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(CargarClientes(), CargarAuxiliares());
        _cargando = false;
    }

    private async Task CargarClientes()
    {
        try
        {
            var r = await Http.GetFromJsonAsync<ApiResponse<List<ClienteItem>>>("api/v1/clientes?limit=500");
            if (r?.Ok == true)
            {
                _clientes = r.Data ?? new();
            }
        }
        catch
        {
        }
    }

    private async Task CargarAuxiliares()
    {
        try
        {
            var r = await Http.GetFromJsonAsync<ApiResponse<List<AuxiliarItem>>>("api/v1/usuarios?rol=auxiliar&activo=true&limit=100");
            if (r?.Ok == true && (r.Data?.Count ?? 0) > 0)
            {
                _auxiliares = (r.Data ?? new())
                    .OrderBy(x => x.NombreCompleto)
                    .ToList();
                return;
            }

            var fallback = await Http.GetFromJsonAsync<ApiResponse<List<UsuarioListaItem>>>("api/v1/usuarios?limit=100");
            if (fallback?.Ok == true)
            {
                _auxiliares = (fallback.Data ?? new())
                    .Where(x => x.Activo && string.Equals(x.Rol, "auxiliar", StringComparison.OrdinalIgnoreCase))
                    .Select(x => new AuxiliarItem
                    {
                        UsuarioId = x.UsuarioId,
                        Nombre = x.Nombre,
                        Apellidos = x.Apellidos
                    })
                    .OrderBy(x => x.NombreCompleto)
                    .ToList();
            }
        }
        catch
        {
        }
    }

    private void FiltrarAuxiliar(ChangeEventArgs e)
    {
        long.TryParse(e.Value?.ToString(), out _filtroAuxiliar);
    }

    private void LimpiarFiltros()
    {
        _busqueda = string.Empty;
        _filtroAuxiliar = 0;
    }

    private void AbrirModal(ClienteItem c)
    {
        _clienteSeleccionado = c;
        _auxiliarSeleccionadoId = 0;
        _errorModal = null;
        _modalAsignar = true;
    }

    private void CerrarModal()
    {
        _modalAsignar = false;
        _clienteSeleccionado = null;
        _auxiliarSeleccionadoId = 0;
        _errorModal = null;
    }

    private async Task Asignar()
    {
        if (_clienteSeleccionado == null || _auxiliarSeleccionadoId == 0)
        {
            return;
        }

        _procesando = true;
        _errorModal = null;

        try
        {
            var r = await Http.PostAsJsonAsync(
                $"api/v1/clientes/{_clienteSeleccionado.ClienteId}/asignaciones",
                new { auxiliarId = _auxiliarSeleccionadoId });

            if (r.IsSuccessStatusCode)
            {
                var result = await r.Content.ReadFromJsonAsync<ApiResponse<AsignacionItem>>();
                if (result?.Ok == true && result.Data != null)
                {
                    _clienteSeleccionado.Asignaciones.Add(result.Data);
                    _mensaje = $"Auxiliar asignado a {_clienteSeleccionado.RazonSocial}";
                    _mensajeError = false;
                    CerrarModal();
                    return;
                }
            }

            if (r.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                _errorModal = "Este auxiliar ya esta asignado a este cliente.";
            }
            else
            {
                _errorModal = "No se pudo completar la asignacion.";
            }
        }
        catch (Exception ex)
        {
            _errorModal = ex.Message;
        }
        finally
        {
            _procesando = false;
        }
    }

    private async Task Remover(ClienteItem cliente, AsignacionItem asignacion)
    {
        try
        {
            var r = await Http.DeleteAsync(
                $"api/v1/clientes/{cliente.ClienteId}/asignaciones/{asignacion.AsignacionId}");

            if (r.IsSuccessStatusCode)
            {
                cliente.Asignaciones.Remove(asignacion);
                _mensaje = "Asignacion removida.";
                _mensajeError = false;
            }
        }
        catch
        {
            _mensaje = "No se pudo remover la asignacion.";
            _mensajeError = true;
        }
    }

    private class ClienteItem
    {
        public long ClienteId { get; set; }
        public string Rfc { get; set; } = "";
        public string RazonSocial { get; set; } = "";
        public List<AsignacionItem> Asignaciones { get; set; } = new();
    }

    private class AuxiliarItem
    {
        public long UsuarioId { get; set; }
        public string Nombre { get; set; } = "";
        public string Apellidos { get; set; } = "";
        public string NombreCompleto => $"{Nombre} {Apellidos}".Trim();
    }

    private class UsuarioListaItem
    {
        public long UsuarioId { get; set; }
        public string Nombre { get; set; } = "";
        public string Apellidos { get; set; } = "";
        public string Rol { get; set; } = "";
        public bool Activo { get; set; }
    }

    private class AsignacionItem
    {
        public long AsignacionId { get; set; }
        public long AuxiliarId { get; set; }
        public string AuxiliarNombre { get; set; } = "";
    }
}
